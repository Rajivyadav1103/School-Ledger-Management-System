@{
    ViewData["Title"] = "Fee Payment System";
}

<style>
    @@media print {
        .no-print {
            display: none !important;
        }

        .receipt-card {
            box-shadow: none;
            border: 1px solid #ddd;
        }
    }

    .receipt-card {
        background: white;
        padding: 20px;
        border-radius: 10px;
        box-shadow: 0 0 10px rgba(0,0,0,0.1);
        max-width: 800px;
        margin: 0 auto;
    }

    .fee-item {
        cursor: pointer;
        transition: all 0.2s;
        border: 1px solid #dee2e6;
        margin-bottom: 10px;
        border-radius: 5px;
        padding: 10px;
    }

        .fee-item:hover {
            background-color: #f8f9fa;
            transform: translateX(5px);
        }

    .search-result-item {
        cursor: pointer;
        transition: all 0.2s;
        border: 1px solid #dee2e6;
        margin-bottom: 10px;
        padding: 12px;
        border-radius: 5px;
    }

        .search-result-item:hover {
            background-color: #e3f2fd;
        }

    .status-paid {
        color: green;
        font-weight: bold;
    }

    .status-due {
        color: red;
        font-weight: bold;
    }

    .today-row {
        background-color: #e8f5e9;
    }

    .overall-summary {
        background-color: #e9ecef;
        padding: 10px;
        border-radius: 8px;
        margin-bottom: 15px;
    }

    .selected-summary {
        background-color: #d1ecf1;
        padding: 10px;
        border-radius: 8px;
        margin-bottom: 15px;
        border: 1px solid #bee5eb;
    }

    .nepali-date-box {
        background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
        padding: 10px 15px;
        border-radius: 8px;
    }

    .fee-paid-badge {
        background-color: #28a745;
        color: white;
        padding: 2px 8px;
        border-radius: 12px;
        font-size: 11px;
        margin-left: 5px;
    }

    .fee-type-badge {
        padding: 2px 8px;
        border-radius: 12px;
        font-size: 10px;
        margin-left: 5px;
    }

        .fee-type-badge.one-time {
            background-color: #17a2b8;
            color: white;
        }

        .fee-type-badge.monthly {
            background-color: #28a745;
            color: white;
        }

    .receipt-header {
        text-align: center;
        margin-bottom: 20px;
    }

    .receipt-school-name {
        font-size: 24px;
        font-weight: bold;
    }

    .receipt-title {
        font-size: 18px;
        margin-top: 5px;
    }

    .receipt-divider {
        border-top: 2px dashed #333;
        margin: 15px 0;
    }

    .receipt-table {
        width: 100%;
        border-collapse: collapse;
        margin: 10px 0;
    }

        .receipt-table th,
        .receipt-table td {
            border: 1px solid #ddd;
            padding: 8px;
            text-align: left;
        }

        .receipt-table th {
            background-color: #f2f2f2;
        }

        .receipt-table .section-header {
            background-color: #e9ecef;
            font-weight: bold;
            text-align: center;
        }

    .receipt-footer {
        text-align: center;
        margin-top: 20px;
        font-size: 12px;
    }

    .receipt-nepali-date {
        background: #f0f8ff;
        padding: 5px 10px;
        border-radius: 5px;
        font-size: 14px;
    }

    .remaining-due-box {
        background-color: #fff3cd;
        border: 1px solid #ffc107;
        padding: 10px;
        border-radius: 5px;
        margin-bottom: 10px;
    }

    .fee-section-title {
        font-weight: bold;
        padding: 5px 10px;
        border-radius: 5px;
        margin: 10px 0;
    }

        .fee-section-title.one-time {
            background-color: #d1ecf1;
            border-left: 4px solid #17a2b8;
        }

        .fee-section-title.monthly {
            background-color: #d4edda;
            border-left: 4px solid #28a745;
        }

    .receipt-summary-box {
        background-color: #f8f9fa;
        border: 1px solid #dee2e6;
        border-radius: 5px;
        padding: 15px;
        margin: 10px 0;
    }

        .receipt-summary-box .row {
            padding: 3px 0;
        }

        .receipt-summary-box .label {
            font-weight: 600;
        }

        .receipt-summary-box .value {
            text-align: right;
            font-weight: 600;
        }

        .receipt-summary-box .total {
            font-size: 16px;
            border-top: 2px solid #333;
            padding-top: 8px;
            margin-top: 5px;
        }
</style>

<link href="https://cdn.datatables.net/1.13.8/css/jquery.dataTables.min.css" rel="stylesheet">
<link href="https://cdn.datatables.net/buttons/2.4.2/css/buttons.dataTables.min.css" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet">

<div class="container-fluid mt-3">
    <h2 class="text-center mb-4">💰 Fee Payment System</h2>
    <hr />

    <div class="row mb-3 no-print">
        <div class="col-md-6">
            <div class="nepali-date-box">
                <strong><i class="fas fa-calendar-alt"></i> Today's Date:</strong>
                <span id="nepaliDateDisplay">Loading...</span>
                <span class="badge bg-info ms-2">🇳🇵 Nepali Date</span>
            </div>
        </div>
        <div class="col-md-6 text-end">
            <span class="badge bg-success">💳 Payment System v2.0</span>
        </div>
    </div>

    <!-- Search Student Section -->
    <div class="card no-print mb-4">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><i class="fas fa-search"></i> Search Student</h5>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-10">
                    <div class="input-group">
                        <input type="text" class="form-control form-control-lg" id="searchStudent"
                               placeholder="Search by Name, Roll Number, or Father's Name..." />
                        <button class="btn btn-primary" id="btnSearch"><i class="fas fa-search"></i> Search</button>
                        <button class="btn btn-secondary" id="btnClearSearch"><i class="fas fa-times"></i> Clear</button>
                    </div>
                    <small class="text-muted">Type at least 2 characters and click Search or press Enter</small>
                </div>
            </div>
            <div id="searchResults" style="max-height: 400px; overflow-y: auto; display: none; margin-top: 15px;"></div>
        </div>
    </div>

    <!-- Payment Section -->
    <div id="paymentSection" style="display: none;">
        <div class="card mb-4">
            <div class="card-header bg-success text-white">
                <h5 class="mb-0"><i class="fas fa-user-graduate"></i> Student Information</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-3"><strong>Student Name:</strong> <span id="displayStudentName"></span></div>
                    <div class="col-md-2"><strong>Roll No:</strong> <span id="displayRollNo"></span></div>
                    <div class="col-md-2"><strong>Class:</strong> <span id="displayClass"></span></div>
                    <div class="col-md-3"><strong>Father's Name:</strong> <span id="displayFatherName"></span></div>
                    <div class="col-md-2"><strong>Contact:</strong> <span id="displayContact"></span></div>
                </div>
                <div class="row mt-2">
                    <div class="col-md-12">
                        <div class="alert alert-info mb-0">
                            <strong><i class="fas fa-info-circle"></i> Note:</strong>
                            <span class="badge bg-info">One-Time Fee</span> - Not multiplied by months
                            <span class="badge bg-success" style="margin-left:10px;">Monthly Fee</span> - Multiplied by months
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <input type="hidden" id="hdnStudentId" value="0" />

        <div class="row">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
                        <h5 class="mb-0"><i class="fas fa-list"></i> Select Fees to Pay</h5>
                        <span class="badge bg-light text-dark" id="feeCount">0 fees selected</span>
                    </div>
                    <div class="card-body" id="feeList" style="max-height: 500px; overflow-y: auto;">
                        <div class="text-center text-muted">Loading fees...</div>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card">
                    <div class="card-header bg-warning">
                        <h5 class="mb-0"><i class="fas fa-calculator"></i> Payment Summary</h5>
                    </div>
                    <div class="card-body">
                        <div class="overall-summary">
                            <h6 class="text-muted mb-2">Overall Fee Summary (All Fees)</h6>
                            <div class="row text-center">
                                <div class="col-3"><small>Total Fee</small><h5 id="totalAmount">₹ 0</h5></div>
                                <div class="col-3"><small>Already Paid</small><h5 id="totalPaid">₹ 0</h5></div>
                                <div class="col-3"><small>Total Due</small><h5 id="totalDue">₹ 0</h5></div>
                                <div class="col-3"><small>Advance Balance</small><h5 id="advanceBalance">₹ 0</h5></div>
                            </div>
                        </div>

                        <div id="selectedSummary" class="selected-summary" style="display: none;">
                            <h6 class="text-primary mb-2"><i class="fas fa-check-circle"></i> Selected Fees Summary</h6>
                            <div id="selectedFeesBreakdown"></div>
                            <hr class="my-2">
                            <div class="row">
                                <div class="col-6"><strong>One-Time Fees Total:</strong></div>
                                <div class="col-6 text-end"><strong id="oneTimeFeesTotal">₹ 0</strong></div>
                            </div>
                            <div class="row">
                                <div class="col-6"><strong>Monthly Fees Total:</strong></div>
                                <div class="col-6 text-end"><strong id="monthlyFeesTotal">₹ 0</strong></div>
                            </div>
                            <div class="row">
                                <div class="col-6"><strong>Months:</strong></div>
                                <div class="col-6 text-end"><strong id="selectedMonths">0</strong></div>
                            </div>
                            <div class="row">
                                <div class="col-6"><strong>Monthly Total (× Months):</strong></div>
                                <div class="col-6 text-end"><strong id="monthlyTotalWithMonths">₹ 0</strong></div>
                            </div>
                            <div class="row">
                                <div class="col-6"><strong>Grand Total:</strong></div>
                                <div class="col-6 text-end"><strong id="grandTotalSummary">₹ 0</strong></div>
                            </div>
                        </div>

                        <!-- Manual Month Input -->
                        <div class="mb-3">
                            <label class="form-label fw-bold">Number of Months <span class="text-danger">*</span></label>
                            <input type="number" class="form-control" id="txtMonthsToPay" value="1" min="1" max="12" />
                            <small class="text-muted">Enter how many months you want to pay (1-12)</small>
                        </div>

                        <!-- Remaining Due Section -->
                        <div class="remaining-due-box">
                            <div class="row">
                                <div class="col-8">
                                    <strong>Remaining Due:</strong>
                                    <span id="displayRemainingDueAmount" class="text-danger">₹ 0.00</span>
                                    <small class="text-muted d-block">Previous outstanding balance</small>
                                </div>
                                <div class="col-4 text-end">
                                    <button class="btn btn-sm btn-warning" id="btnAddRemainingDue">
                                        <i class="fas fa-plus"></i> Add to Bill
                                    </button>
                                </div>
                            </div>
                            <div id="remainingDueSection" style="display: none;" class="mt-2">
                                <div class="input-group">
                                    <span class="input-group-text">₹</span>
                                    <input type="number" class="form-control" id="txtRemainingDue" value="0" step="0.01" min="0" />
                                    <button class="btn btn-danger" id="btnRemoveRemainingDue">
                                        <i class="fas fa-times"></i> Remove
                                    </button>
                                </div>
                                <small class="text-muted">Edit the remaining due amount if needed</small>
                            </div>
                        </div>

                        <!-- Discount Section -->
                        <div class="row">
                            <div class="col-12 mb-3">
                                <label class="form-label fw-bold">Discount (₹)</label>
                                <input type="number" class="form-control" id="txtDiscount" value="0" step="0.01" min="0" />
                                <small class="text-muted">Apply discount to total amount</small>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-6 mb-3">
                                <label class="form-label fw-bold">Payment Amount <span class="text-danger">*</span></label>
                                <input type="number" class="form-control" id="txtPaymentAmount" step="0.01" min="0" placeholder="Enter amount" />
                            </div>
                            <div class="col-6 mb-3">
                                <label class="form-label fw-bold">Payment Method</label>
                                <select class="form-select" id="ddlPaymentMethod">
                                    <option value="Cash">💵 Cash</option>
                                    <option value="Bank Transfer">🏦 Bank Transfer</option>
                                    <option value="Online">💻 Online</option>
                                    <option value="Card">💳 Card</option>
                                </select>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-6 mb-3">
                                <label class="form-label fw-bold">Payment Date</label>
                                <input type="date" class="form-control" id="txtPaymentDate" />
                            </div>
                            <div class="col-6 mb-3">
                                <label class="form-label fw-bold">Invoice No</label>
                                <input type="text" class="form-control" id="txtInvoiceNo" readonly style="background:#f8f9fa" />
                            </div>
                        </div>

                        <!-- Payment Calculation Details -->
                        <div class="alert alert-info">
                            <strong>Payment Details:</strong><br />
                            <div class="row"><div class="col-6">One-Time Fees:</div><div class="col-6 text-end" id="displayOneTimeFees">₹ 0</div></div>
                            <div class="row"><div class="col-6">Monthly Fees:</div><div class="col-6 text-end" id="displayMonthlyFees">₹ 0</div></div>
                            <div class="row"><div class="col-6">× Months:</div><div class="col-6 text-end" id="displayMonthsCount">0</div></div>
                            <div class="row"><div class="col-6">Monthly Total (× Months):</div><div class="col-6 text-end" id="displayMonthlyTotal">₹ 0</div></div>
                            <div class="row"><div class="col-6">Remaining Due:</div><div class="col-6 text-end text-warning" id="displayRemainingDue">₹ 0</div></div>
                            <div class="row"><div class="col-6"><strong>Grand Total:</strong></div><div class="col-6 text-end"><strong id="displayGrandTotal">₹ 0</strong></div></div>
                            <div class="row"><div class="col-6 text-success">Discount Applied:</div><div class="col-6 text-end text-success" id="displayDiscount">- ₹ 0</div></div>
                            <hr />
                            <div class="row"><div class="col-6"><strong>Total to Pay:</strong></div><div class="col-6 text-end"><strong id="lblNetPayable" style="font-size: 18px;">₹ 0</strong></div></div>
                            <div class="row"><div class="col-6"><strong>Remaining Due After:</strong></div><div class="col-6 text-end text-warning"><strong id="remainingDueAfter">₹ 0</strong></div></div>
                        </div>

                        <div class="d-grid gap-2">
                            <button class="btn btn-success btn-lg btn-process-payment"><i class="fas fa-money-bill-wave"></i> Process Payment</button>
                            <button class="btn btn-danger btn-cancel-payment"><i class="fas fa-times"></i> Cancel</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card mt-4">
            <div class="card-header bg-secondary text-white">
                <h5 class="mb-0"><i class="fas fa-history"></i> Payment History</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-bordered">
                        <thead class="table-dark">
                            <tr><th>Date</th><th>Invoice No</th><th>Fee Name</th><th>Amount</th><th>Discount</th><th>Method</th><th>Status</th><th>Actions</th></tr>
                        </thead>
                        <tbody id="paymentHistoryBody"><tr><td colspan="8" class="text-center">No payment history</td></tr></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Today's Payments -->
    <div class="card mb-4 mt-4">
        <div class="card-header bg-success text-white">
            <h5 class="mb-0"><i class="fas fa-calendar-day"></i> Today's Payments (<span id="todayDate"></span>)</h5>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered" id="todayPaymentsTable">
                    <thead class="table-dark"><tr><th>Time</th><th>Invoice No</th><th>Student Name</th><th>Roll No</th><th>Amount</th><th>Discount</th><th>Method</th><th>Action</th></tr></thead>
                    <tbody id="tblTodayPayments"><tr><td colspan="8" class="text-center">No payments today</td></tr></tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- All Payments History -->
    <div class="card">
        <div class="card-header bg-info text-white">
            <h5 class="mb-0"><i class="fas fa-history"></i> All Payments History</h5>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered table-striped" id="allPaymentsTable">
                    <thead class="table-dark">
                        <tr><th>Date</th><th>Invoice No</th><th>Student Name</th><th>Roll No</th><th>Class</th><th>Amount</th><th>Discount</th><th>Status</th><th>Actions</th></tr>
                    </thead>
                    <tbody id="tblAllPayments"><tr><td colspan="9" class="text-center">No payments found</td></tr></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Edit Payment Modal -->
<div class="modal fade" id="editPaymentModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-warning">
                <h5 class="modal-title"><i class="fas fa-edit"></i> Edit Payment</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="editInvoiceNo" />
                <div class="mb-3">
                    <label>Amount (₹)</label>
                    <input type="number" class="form-control" id="editAmount" step="0.01" />
                </div>
                <div class="mb-3">
                    <label>Discount (₹)</label>
                    <input type="number" class="form-control" id="editDiscount" step="0.01" />
                </div>
                <div class="mb-3">
                    <label>Payment Method</label>
                    <select class="form-select" id="editMethod">
                        <option value="Cash">Cash</option>
                        <option value="Bank Transfer">Bank Transfer</option>
                        <option value="Online">Online</option>
                        <option value="Card">Card</option>
                    </select>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-primary btn-update-payment">Update Payment</button>
                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            </div>
        </div>
    </div>
</div>

<!-- Receipt Modal -->
<div class="modal fade" id="receiptModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title"><i class="fas fa-receipt"></i> Payment Receipt</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="receiptContent"></div>
            <div class="modal-footer no-print">
                <button class="btn btn-primary btn-print-receipt"><i class="fas fa-print"></i> Print Receipt</button>
                <button class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/buttons/2.4.2/js/dataTables.buttons.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>
<script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.html5.min.js"></script>
<script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.print.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

<script>
    let selectedStudentId = 0;
    let selectedFees = [];
    let dataTable;
    let editModal;
    let receiptModal;
    let currentStudentData = null;
    let isRemainingDueAdded = false;

    // Define one-time fee names
    const oneTimeFeeNames = ['Admission', 'Registration', 'Exam', 'Development', 'Annual'];

    $(document).ready(function() {
        let today = new Date();
        $('#todayDate').text(today.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }));
        $('#txtPaymentDate').val(today.toISOString().split('T')[0]);

        editModal = new bootstrap.Modal(document.getElementById('editPaymentModal'));
        receiptModal = new bootstrap.Modal(document.getElementById('receiptModal'));

        loadTodayPayments();
        loadAllPayments();
        loadNepaliDate();

        toastr.options = { "closeButton": true, "progressBar": true, "positionClass": "toast-top-right", "timeOut": "3000" };
    });

    function loadNepaliDate() {
        $.ajax({
            url: '/FeePayment/GetNepaliDate',
            type: 'GET',
            success: function(res) {
                if (res.success) {
                    $('#nepaliDateDisplay').html('<strong>' + res.date + '</strong>');
                }
            }
        });
    }

    // Search Students
    $('#btnSearch').click(function() {
        let searchTerm = $('#searchStudent').val().trim();
        if (searchTerm.length < 2) { toastr.warning('Please enter at least 2 characters'); return; }
        $.ajax({ url: '/FeePayment/SearchStudents', type: 'GET', data: { searchTerm: searchTerm }, success: displaySearchResults, error: () => toastr.error('Error searching students') });
    });

    $('#searchStudent').keypress(function(e) { if (e.which == 13) $('#btnSearch').click(); });
    $('#btnClearSearch').click(function() { $('#searchStudent').val(''); $('#searchResults').hide(); });

    function displaySearchResults(students) {
        if (!students || students.length === 0) { $('#searchResults').html('<div class="alert alert-warning">No students found</div>').show(); return; }
        let html = '<div class="list-group">';
        students.forEach(s => {
            html += `<div class="list-group-item search-result-item" data-id="${s.studentID}">
                <div class="d-flex justify-content-between align-items-center">
                    <div><strong>${escapeHtml(s.studentName)}</strong><br/><small>Roll: ${s.rollNo || 'N/A'} | Class: ${escapeHtml(s.className)} | Father: ${escapeHtml(s.fatherName) || 'N/A'}</small></div>
                    <button class="btn btn-sm btn-success btn-select-student" data-id="${s.studentID}"><i class="fas fa-money-bill"></i> Select</button>
                </div>
            </div>`;
        });
        html += '</div>';
        $('#searchResults').html(html).show();
    }

    $(document).on('click', '.btn-select-student', function(e) { e.stopPropagation(); loadStudentDetails($(this).data('id')); });

    function loadStudentDetails(studentId) {
        $('#searchResults').hide(); $('#searchStudent').val('');
        $.ajax({
            url: '/FeePayment/GetStudentFeeDetails',
            type: 'GET',
            data: { studentId: studentId },
            success: function(res) {
                if (res.success) {
                    selectedStudentId = studentId;
                    currentStudentData = res;
                    $('#hdnStudentId').val(studentId);
                    $('#displayStudentName').text(res.student.studentName);
                    $('#displayRollNo').text(res.student.rollNo || 'N/A');
                    $('#displayClass').text(res.student.className);
                    $('#displayFatherName').text(res.student.fatherName || 'N/A');
                    $('#displayContact').text(res.student.contactNo || 'N/A');
                    $('#totalAmount').text('₹ ' + res.totalFeeAmount.toFixed(2));
                    $('#totalPaid').text('₹ ' + res.totalPaidOverall.toFixed(2));
                    $('#totalDue').text('₹ ' + res.totalDueOverall.toFixed(2));
                    $('#advanceBalance').text('₹ ' + (res.advanceBalance || 0).toFixed(2));

                    $('#displayRemainingDueAmount').text('₹ ' + res.totalDueOverall.toFixed(2));

                    displayFeeList(res.feeStructures);
                    displayPaymentHistory(res.paymentHistory);
                    $('#paymentSection').show();
                    $('#txtInvoiceNo').val('INV-' + new Date().getTime());
                    $('html, body').animate({ scrollTop: $('#paymentSection').offset().top - 50 }, 500);
                } else { toastr.error(res.message); }
            },
            error: () => toastr.error('Error loading student details')
        });
    }

    function displayFeeList(fees) {
        if (!fees || fees.length === 0) {
            $('#feeList').html('<div class="alert alert-warning">No fees configured for this class</div>');
            return;
        }

        let html = '';
        fees.forEach(fee => {
            let statusClass = fee.isFullyPaid ? 'status-paid' : 'status-due';
            let statusText = fee.isFullyPaid ? '✅ Paid - Select for new month' : `Due: ₹${fee.dueAmount.toFixed(2)}`;
            let bgColor = fee.isFullyPaid ? '#d4edda' : 'white';

            let isOneTime = oneTimeFeeNames.some(f => fee.feeName.toLowerCase().includes(f.toLowerCase()));
            let feeType = isOneTime ? 'one-time' : 'monthly';
            let feeTypeBadge = feeType === 'one-time' ?
                '<span class="fee-type-badge one-time">One-Time</span>' :
                '<span class="fee-type-badge monthly">Monthly</span>';

            html += `<div class="fee-item" style="background:${bgColor}"
                     data-id="${fee.feeStructureID}"
                     data-name="${escapeHtml(fee.feeName)}"
                     data-amount="${fee.amount}"
                     data-due="${fee.dueAmount}"
                     data-paid="${fee.totalPaid}"
                     data-academic="${fee.academicYear}"
                     data-type="${feeType}">
                <div class="form-check">
                    <input class="form-check-input fee-checkbox" type="checkbox"
                           value="${fee.feeStructureID}"
                           id="fee_${fee.feeStructureID}"
                           data-due="${fee.dueAmount}"
                           data-type="${feeType}">
                    <label class="form-check-label" for="fee_${fee.feeStructureID}">
                        <strong>${escapeHtml(fee.feeName)}</strong>
                        ${fee.isFullyPaid ? '<span class="fee-paid-badge"><i class="fas fa-check"></i> Paid</span>' : ''}
                        ${feeTypeBadge}
                        <br/>
                        <small>Amount: ₹${fee.amount.toFixed(2)} | Paid: ₹${fee.totalPaid.toFixed(2)} | <span class="${statusClass}">${statusText}</span></small>
                        ${fee.isFullyPaid ? `<br/><small class="text-success">🔄 Select to pay for next month</small>` : ''}
                        ${feeType === 'one-time' ? `<br/><small class="text-info">📌 One-time fee (not multiplied by months)</small>` : `<br/><small class="text-success">📅 Monthly fee (× months)</small>`}
                    </label>
                </div>
            </div>`;
        });
        $('#feeList').html(html);

        $('.fee-checkbox').off('change').on('change', function() {
            updateSelectedFees();
            updateFeeCount();
        });

        updateFeeCount();
    }

    function updateFeeCount() {
        let count = $('.fee-checkbox:checked').length;
        $('#feeCount').text(count + ' fee' + (count > 1 ? 's' : '') + ' selected');
    }

    function updateSelectedFees() {
        selectedFees = [];
        $('.fee-checkbox:checked').each(function() {
            let parent = $(this).closest('.fee-item');
            selectedFees.push({
                feeStructureID: parseInt($(this).val()),
                feeName: parent.data('name'),
                amount: parent.data('amount'),
                dueAmount: parent.data('due'),
                academicYear: parent.data('academic'),
                isFullyPaid: parent.data('due') <= 0,
                feeType: parent.data('type') || 'monthly'
            });
        });
        updateSelectedSummary();
        calculateTotalAmount();
    }

    function updateSelectedSummary() {
        if (selectedFees.length === 0) {
            $('#selectedSummary').hide();
            $('#txtPaymentAmount').attr('max', 0);
            return;
        }

        let oneTimeHtml = '';
        let monthlyHtml = '';
        let monthlyTotal = 0;
        let oneTimeTotal = 0;
        let months = parseInt($('#txtMonthsToPay').val()) || 1;

        selectedFees.forEach(fee => {
            let isMonthly = fee.feeType === 'monthly';
            let status = fee.isFullyPaid ? '🔄 New Month' : 'Due';

            if (isMonthly) {
                monthlyHtml += `<div class="row mb-1">
                    <div class="col-6">${escapeHtml(fee.feeName)} ${fee.isFullyPaid ? '<span class="badge bg-success">New Month</span>' : ''}</div>
                    <div class="col-6 text-end">₹${fee.amount.toFixed(2)} × ${months} = ₹${(fee.amount * months).toFixed(2)}</div>
                </div>`;
                monthlyTotal += fee.amount;
            } else {
                oneTimeHtml += `<div class="row mb-1">
                    <div class="col-6">${escapeHtml(fee.feeName)}</div>
                    <div class="col-6 text-end">₹${fee.amount.toFixed(2)}</div>
                </div>`;
                oneTimeTotal += fee.amount;
            }
        });

        let monthlyTotalWithMonths = monthlyTotal * months;
        let grandTotal = monthlyTotalWithMonths + oneTimeTotal;

        let breakdownHtml = '';
        if (oneTimeHtml) {
            breakdownHtml += `<div class="fee-section-title one-time">📌 One-Time Fees</div>${oneTimeHtml}`;
        }
        if (monthlyHtml) {
            breakdownHtml += `<div class="fee-section-title monthly">📅 Monthly Fees (× ${months} months)</div>${monthlyHtml}`;
        }

        $('#selectedFeesBreakdown').html(breakdownHtml);
        $('#oneTimeFeesTotal').text('₹ ' + oneTimeTotal.toFixed(2));
        $('#monthlyFeesTotal').text('₹ ' + monthlyTotal.toFixed(2));
        $('#selectedMonths').text(months);
        $('#monthlyTotalWithMonths').text('₹ ' + monthlyTotalWithMonths.toFixed(2));
        $('#grandTotalSummary').text('₹ ' + grandTotal.toFixed(2));
        $('#selectedSummary').show();

        calculateTotalAmount();
    }

    function calculateTotalAmount() {
        let monthlyTotal = 0;
        let oneTimeTotal = 0;
        let months = parseInt($('#txtMonthsToPay').val()) || 1;
        let remainingDue = parseFloat($('#txtRemainingDue').val()) || 0;
        let discount = parseFloat($('#txtDiscount').val()) || 0;

        selectedFees.forEach(fee => {
            if (fee.feeType === 'monthly') {
                monthlyTotal += fee.amount;
            } else {
                oneTimeTotal += fee.amount;
            }
        });

        let monthlyTotalWithMonths = monthlyTotal * months;
        let grandTotal = monthlyTotalWithMonths + oneTimeTotal + remainingDue;
        let afterDiscount = grandTotal - discount;
        if (afterDiscount < 0) afterDiscount = 0;

        $('#displayOneTimeFees').text('₹ ' + oneTimeTotal.toFixed(2));
        $('#displayMonthlyFees').text('₹ ' + monthlyTotal.toFixed(2));
        $('#displayMonthsCount').text(months);
        $('#displayMonthlyTotal').text('₹ ' + monthlyTotalWithMonths.toFixed(2));
        $('#displayRemainingDue').text('₹ ' + remainingDue.toFixed(2));
        $('#displayGrandTotal').text('₹ ' + grandTotal.toFixed(2));
        $('#displayDiscount').text('- ₹ ' + discount.toFixed(2));
        $('#lblNetPayable').text('₹ ' + afterDiscount.toFixed(2));

        $('#txtPaymentAmount').attr('max', afterDiscount);
        $('#txtPaymentAmount').attr('placeholder', `Max: ₹${afterDiscount.toFixed(2)}`);

        let paymentAmount = parseFloat($('#txtPaymentAmount').val()) || 0;
        let remainingAfter = afterDiscount - paymentAmount;
        if (remainingAfter < 0) remainingAfter = 0;
        $('#remainingDueAfter').text('₹ ' + remainingAfter.toFixed(2));
    }

    $('#txtMonthsToPay, #txtDiscount, #txtRemainingDue').on('keyup change', function() {
        calculateTotalAmount();
        updateSelectedSummary();
    });

    $('#btnAddRemainingDue').click(function() {
        let dueAmount = parseFloat($('#displayRemainingDueAmount').text().replace('₹ ', ''));
        if (dueAmount > 0) {
            $('#txtRemainingDue').val(dueAmount);
            $('#remainingDueSection').show();
            isRemainingDueAdded = true;
            calculateTotalAmount();
            toastr.success('Remaining due added to bill');
        } else {
            toastr.info('No remaining due to add');
        }
    });

    $('#btnRemoveRemainingDue').click(function() {
        $('#txtRemainingDue').val(0);
        $('#remainingDueSection').hide();
        isRemainingDueAdded = false;
        calculateTotalAmount();
        toastr.info('Remaining due removed from bill');
    });

    $('#txtPaymentAmount').on('keyup change', function() {
        let paymentAmount = parseFloat($(this).val()) || 0;
        let maxDue = parseFloat($(this).attr('max')) || 0;
        if (paymentAmount > maxDue && maxDue > 0) {
            $(this).val(maxDue);
            paymentAmount = maxDue;
        }
        let afterDiscount = parseFloat($('#lblNetPayable').text().replace('₹ ', '')) || 0;
        let remainingAfter = afterDiscount - paymentAmount;
        if (remainingAfter < 0) remainingAfter = 0;
        $('#remainingDueAfter').text('₹ ' + remainingAfter.toFixed(2));
    });

    function displayPaymentHistory(payments) {
        if (!payments || payments.length === 0) {
            $('#paymentHistoryBody').html('<tr><td colspan="8" class="text-center">No payment history</td></tr>');
            return;
        }
        let html = '';
        payments.forEach(p => {
            let statusBadge = p.paymentStatus === 'Paid' ? '<span class="badge bg-success">Paid</span>' :
                p.paymentStatus === 'Advance' ? '<span class="badge bg-info">Advance</span>' :
                '<span class="badge bg-warning">Partial</span>';

            let feeName = p.FeeName || 'N/A';
            if (p.FeeName === 'Advance Payment') {
                feeName = '<span class="badge bg-info">📈 Advance</span>';
            }

            html += `<tr>
                <td>${new Date(p.paymentDate).toLocaleDateString()}</td>
                <td><strong>${p.invoiceNo}</strong></td>
                <td>${feeName}</td>
                <td>₹ ${p.paidAmount.toFixed(2)}</td>
                <td>₹ ${(p.discount || 0).toFixed(2)}</td>
                <td>${p.paymentMethod}</td>
                <td>${statusBadge}</td>
                <td>
                    <button class="btn btn-sm btn-info btn-view-receipt" data-invoice="${p.invoiceNo}"><i class="fas fa-print"></i></button>
                </td>
            </tr>`;
        });
        $('#paymentHistoryBody').html(html);
    }

    // Process Payment
    $('.btn-process-payment').click(function() {
        let paymentAmount = parseFloat($('#txtPaymentAmount').val());
        let discount = parseFloat($('#txtDiscount').val()) || 0;
        let months = parseInt($('#txtMonthsToPay').val()) || 1;
        let remainingDue = parseFloat($('#txtRemainingDue').val()) || 0;
        let selectedFeeIds = [];
        let selectedFeesData = [];

        $('.fee-checkbox:checked').each(function() {
            let parent = $(this).closest('.fee-item');
            let feeType = parent.data('type') || 'monthly';
            selectedFeeIds.push(parseInt($(this).val()));
            selectedFeesData.push({
                feeStructureID: parseInt($(this).val()),
                feeName: parent.data('name'),
                amount: parent.data('amount'),
                dueAmount: parent.data('due'),
                academicYear: parent.data('academic'),
                feeType: feeType
            });
        });

        if (selectedFeeIds.length === 0) { toastr.warning('Please select at least one fee to pay'); return; }
        if (!paymentAmount || paymentAmount <= 0) { toastr.warning('Please enter payment amount'); return; }

        let monthlyTotal = 0;
        let oneTimeTotal = 0;
        selectedFeesData.forEach(fee => {
            if (fee.feeType === 'monthly') {
                monthlyTotal += fee.amount;
            } else {
                oneTimeTotal += fee.amount;
            }
        });

        let monthlyTotalWithMonths = monthlyTotal * months;
        let grandTotal = monthlyTotalWithMonths + oneTimeTotal + remainingDue;
        let afterDiscount = grandTotal - discount;
        if (afterDiscount < 0) afterDiscount = 0;

        if (paymentAmount > afterDiscount) {
            toastr.warning(`Payment amount cannot exceed ₹${afterDiscount.toFixed(2)}`);
            return;
        }

        let data = {
            StudentID: selectedStudentId,
            FeeStructureIds: selectedFeeIds,
            SelectedFees: selectedFeesData,
            PaidAmount: paymentAmount,
            Discount: discount,
            MonthsToPay: months,
            RemainingDue: remainingDue,
            PaymentMethod: $('#ddlPaymentMethod').val(),
            PaymentDate: $('#txtPaymentDate').val(),
            InvoiceNo: $('#txtInvoiceNo').val(),
            TotalDue: grandTotal,
            AfterDiscount: afterDiscount,
            MonthlyTotal: monthlyTotal,
            OneTimeTotal: oneTimeTotal,
            MonthlyTotalWithMonths: monthlyTotalWithMonths
        };

        console.log('Sending data:', data);

        $.ajax({
            url: '/FeePayment/SaveBulkPayment',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(data),
            success: function(res) {
                if (res.success) {
                    toastr.success('Payment processed successfully!');
                    showReceipt(res.invoiceNo);
                    loadStudentDetails(selectedStudentId);
                    loadTodayPayments();
                    loadAllPayments();
                    $('.fee-checkbox:checked').prop('checked', false);
                    $('#txtPaymentAmount').val('');
                    $('#txtDiscount').val('0');
                    $('#txtRemainingDue').val('0');
                    $('#remainingDueSection').hide();
                    isRemainingDueAdded = false;
                    selectedFees = [];
                    updateSelectedSummary();
                    updateFeeCount();
                } else { toastr.error(res.message); }
            },
            error: function(xhr) {
                console.log('Error:', xhr);
                toastr.error(xhr.responseJSON?.message || 'Error processing payment');
            }
        });
    });

    $('.btn-cancel-payment').click(function() {
        $('#paymentSection').hide();
        $('#searchStudent').val('');
        $('#searchResults').hide();
        selectedStudentId = 0;
        selectedFees = [];
    });

