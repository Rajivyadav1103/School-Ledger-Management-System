                        </div>
                        <div class="row">
                            <div class="col-6 label text-warning"><strong>Remaining Due After:</strong></div>
                            <div class="col-6 value text-warning"><strong>₹ ${dueAmt.toFixed(2)}</strong></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="receipt-divider"></div>

            <div class="receipt-footer">
                <p><strong>✅ Thank you for your payment!</strong></p>
                <small>This is a computer generated receipt | Nepali Date: ${receipt.nepaliDate || 'N/A'}</small>
            </div>
        </div>`;

        $('#receiptContent').html(receiptHtml);
    }

    $('.btn-print-receipt').click(function() {
        let printContents = $('#receiptContent').html();
        let originalContents = document.body.innerHTML;
        document.body.innerHTML = printContents;
        window.print();
        document.body.innerHTML = originalContents;
        location.reload();
    });

    $(document).on('click', '.btn-edit-payment', function() {
        let invoiceNo = $(this).data('invoice');
        let amount = $(this).data('amount');
        let discount = $(this).data('discount');
        let method = $(this).data('method');

        $('#editInvoiceNo').val(invoiceNo);
        $('#editAmount').val(amount);
        $('#editDiscount').val(discount);
        $('#editMethod').val(method);
        editModal.show();
    });

    $('.btn-update-payment').click(function() {
        let data = {
            InvoiceNo: $('#editInvoiceNo').val(),
            PaidAmount: $('#editAmount').val(),
            Discount: $('#editDiscount').val(),
            PaymentMethod: $('#editMethod').val()
        };

        $.ajax({
            url: '/FeePayment/EditPayment',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(data),
            success: function(res) {
                if (res.success) {
                    toastr.success('Payment updated successfully');
                    editModal.hide();
                    loadStudentDetails(selectedStudentId);
                    loadTodayPayments();
                    loadAllPayments();
                } else { toastr.error(res.message); }
            }
        });
    });

    $(document).on('click', '.btn-delete-payment', function() {
        let invoiceNo = $(this).data('invoice');
        if (confirm('Are you sure you want to delete this payment? This action cannot be undone!')) {
            $.ajax({
                url: '/FeePayment/DeletePayment',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(invoiceNo),
                success: function(res) {
                    if (res.success) {
                        toastr.success('Payment deleted successfully');
                        loadStudentDetails(selectedStudentId);
                        loadTodayPayments();
                        loadAllPayments();
                    } else { toastr.error(res.message); }
                }
            });
        }
    });

    function loadTodayPayments() {
        $.ajax({
            url: '/FeePayment/GetTodayPayments',
            type: 'GET',
            success: function(payments) {
                let html = '';
                if (payments && payments.length > 0) {
                    payments.forEach(p => {
                        html += `<tr class="today-row">
                            <td>${new Date(p.paymentDate).toLocaleTimeString()}</td>
                            <td><strong>${p.invoiceNo}</strong></td>
                            <td>${escapeHtml(p.studentName)}</td>
                            <td>${p.rollNo || '-'}</td>
                            <td>₹ ${p.totalAmount.toFixed(2)}</td>
                            <td>₹ ${(p.discount || 0).toFixed(2)}</td>
                            <td>${p.paymentMethod}</td>
                            <td><button class="btn btn-sm btn-info btn-view-receipt" data-invoice="${p.invoiceNo}"><i class="fas fa-print"></i></button></td>
                        </tr>`;
                    });
                } else {
                    html = '<tr><td colspan="8" class="text-center">No payments today</td></tr>';
                }
                $('#tblTodayPayments').html(html);
            }
        });
    }

    function loadAllPayments() {
        $.ajax({
            url: '/FeePayment/GetAllPayments',
            type: 'GET',
            success: function(payments) {
                let html = '';
                if (payments && payments.length > 0) {
                    payments.forEach(p => {
                        let status = p.dueAfter <= 0 ? 'Paid' : 'Partial';
                        let statusBadge = status === 'Paid' ?
                            '<span class="badge bg-success">Paid</span>' :
                            '<span class="badge bg-warning">Partial</span>';

                        html += `<tr>
                            <td>${new Date(p.paymentDate).toLocaleDateString()}</td>
                            <td><strong>${p.invoiceNo}</strong></td>
                            <td>${escapeHtml(p.studentName)}</td>
                            <td>${p.rollNo || '-'}</td>
                            <td>${escapeHtml(p.className)}</td>
                            <td>₹ ${p.totalAmount.toFixed(2)}</td>
                            <td>₹ ${(p.discount || 0).toFixed(2)}</td>
                            <td>${statusBadge}</td>
                            <td>
                                <button class="btn btn-sm btn-warning btn-edit-payment" data-invoice="${p.invoiceNo}" data-amount="${p.totalAmount}" data-discount="${p.discount}" data-method="${p.paymentMethod}"><i class="fas fa-edit"></i></button>
                                <button class="btn btn-sm btn-danger btn-delete-payment" data-invoice="${p.invoiceNo}"><i class="fas fa-trash"></i></button>
                                <button class="btn btn-sm btn-info btn-view-receipt" data-invoice="${p.invoiceNo}"><i class="fas fa-print"></i></button>
                            </td>
                        </tr>`;
                    });
                } else {
                    html = '<tr><td colspan="9" class="text-center">No payments found</td></tr>';
                }
                $('#tblAllPayments').html(html);

                if ($.fn.DataTable.isDataTable('#allPaymentsTable')) {
                    $('#allPaymentsTable').DataTable().destroy();
                }

                dataTable = $('#allPaymentsTable').DataTable({
                    dom: 'Bfrtip',
                    buttons: [
                        { extend: 'copy', className: 'btn-sm' },
                        { extend: 'csv', className: 'btn-sm' },
                        { extend: 'excel', className: 'btn-sm', title: 'Payments_History' },
                        { extend: 'pdf', className: 'btn-sm', title: 'Payments_History' },
                        { extend: 'print', className: 'btn-sm', title: 'Payments History Report' }
                    ],
                    pageLength: 10,
                    lengthMenu: [
                        [10, 25, 50, 100, -1],
                        [10, 25, 50, 100, "All"]
                    ],
                    language: { search: "Search:", lengthMenu: "Show _MENU_ entries", info: "Showing _START_ to _END_ of _TOTAL_ entries" },
                    order: [
                        [0, 'desc']
                    ]
                });
            }
        });
    }

    $(document).on('click', '.btn-view-receipt', function() {
        showReceipt($(this).data('invoice'));
    });

    function escapeHtml(str) {
        if (!str) return '';
        return str.replace(/[&<>]/g, function(m) {
            if (m === '&') return '&amp;';
            if (m === '<') return '&lt;';
            if (m === '>') return '&gt;';
            return m;
        });
    }
</script>