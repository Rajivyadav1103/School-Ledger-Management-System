@{
    ViewData["Title"] = "Fee Payment System";
}

<style>
    @@media print {
        .no-print {
            display: none !important;
        }

        .receipt-card {
            box-shadow: none;
            border: 1px solid #ddd;
        }
    }

    .receipt-card {
        background: white;
        padding: 20px;
        border-radius: 10px;
        box-shadow: 0 0 10px rgba(0,0,0,0.1);
        max-width: 800px;
        margin: 0 auto;
    }

    .fee-item {
        cursor: pointer;
        transition: all 0.2s;
        border: 1px solid #dee2e6;
        margin-bottom: 10px;
        border-radius: 5px;
        padding: 10px;
    }

        .fee-item:hover {
            background-color: #f8f9fa;
            transform: translateX(5px);
        }

    .search-result-item {
        cursor: pointer;
        transition: all 0.2s;
        border: 1px solid #dee2e6;
        margin-bottom: 10px;
        padding: 12px;
        border-radius: 5px;
    }

        .search-result-item:hover {
            background-color: #e3f2fd;
        }

    .summary-card {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border-radius: 10px;
        padding: 20px;
        margin-bottom: 20px;
    }

    .status-paid {
        color: green;
        font-weight: bold;
    }

    .status-due {
        color: red;
        font-weight: bold;
    }

    .today-row {
        background-color: #e8f5e9;
    }

    .overall-summary {
        background-color: #e9ecef;
        padding: 10px;
        border-radius: 8px;
        margin-bottom: 15px;
    }

    .selected-summary {
        background-color: #d1ecf1;
        padding: 10px;
        border-radius: 8px;
        margin-bottom: 15px;
        border: 1px solid #bee5eb;
    }

    .payment-type-btn {
        margin: 5px;
        padding: 8px 15px;
        border-radius: 20px;
        cursor: pointer;
        transition: all 0.3s;
    }

        .payment-type-btn.active {
            background-color: #28a745;
            color: white;
        }

        .payment-type-btn.inactive {
            background-color: #6c757d;
            color: white;
        }

    .nepali-date-box {
        background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
        padding: 10px 15px;
        border-radius: 8px;
    }

    .fee-paid-badge {
        background-color: #28a745;
        color: white;
        padding: 2px 8px;
        border-radius: 12px;
        font-size: 11px;
        margin-left: 5px;
    }

    .receipt-header {
        text-align: center;
        margin-bottom: 20px;
    }

    .receipt-school-name {
        font-size: 24px;
        font-weight: bold;
    }

    .receipt-title {
        font-size: 18px;
        margin-top: 5px;
    }

    .receipt-divider {
        border-top: 2px dashed #333;
        margin: 15px 0;
    }

    .receipt-table {
        width: 100%;
        border-collapse: collapse;
        margin: 10px 0;
    }

        .receipt-table th, .receipt-table td {
            border: 1px solid #ddd;
            padding: 8px;
            text-align: left;
        }

        .receipt-table th {
            background-color: #f2f2f2;
        }

    .receipt-footer {
        text-align: center;
        margin-top: 20px;
        font-size: 12px;
    }

    .receipt-nepali-date {
        background: #f0f8ff;
        padding: 5px 10px;
        border-radius: 5px;
        font-size: 14px;
    }
</style>

<link href="https://cdn.datatables.net/1.13.8/css/jquery.dataTables.min.css" rel="stylesheet">
<link href="https://cdn.datatables.net/buttons/2.4.2/css/buttons.dataTables.min.css" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet">

<div class="container-fluid mt-3">
    <h2 class="text-center mb-4">💰 Fee Payment System</h2>
    <hr />

    <div class="row mb-3 no-print">
        <div class="col-md-6">
            <div class="nepali-date-box">
                <strong><i class="fas fa-calendar-alt"></i> Today's Date:</strong>
                <span id="nepaliDateDisplay">Loading...</span>
                <span class="badge bg-info ms-2">🇳🇵 Nepali Date</span>
            </div>
        </div>
        <div class="col-md-6 text-end">
            <span class="badge bg-success">💳 Payment System v2.0</span>
        </div>
    </div>

    <!-- Search Student Section -->
    <div class="card no-print mb-4">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><i class="fas fa-search"></i> Search Student</h5>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-10">
                    <div class="input-group">
                        <input type="text" class="form-control form-control-lg" id="searchStudent"
                               placeholder="Search by Name, Roll Number, or Father's Name..." />
                        <button class="btn btn-primary" id="btnSearch"><i class="fas fa-search"></i> Search</button>
                        <button class="btn btn-secondary" id="btnClearSearch"><i class="fas fa-times"></i> Clear</button>
                    </div>
                    <small class="text-muted">Type at least 2 characters and click Search or press Enter</small>
                </div>
            </div>
            <div id="searchResults" style="max-height: 400px; overflow-y: auto; display: none; margin-top: 15px;"></div>
        </div>
    </div>

    <!-- Payment Section -->
    <div id="paymentSection" style="display: none;">
        <div class="card mb-4">
            <div class="card-header bg-success text-white">
                <h5 class="mb-0"><i class="fas fa-user-graduate"></i> Student Information</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-3"><strong>Student Name:</strong> <span id="displayStudentName"></span></div>
                    <div class="col-md-2"><strong>Roll No:</strong> <span id="displayRollNo"></span></div>
                    <div class="col-md-2"><strong>Class:</strong> <span id="displayClass"></span></div>
                    <div class="col-md-3"><strong>Father's Name:</strong> <span id="displayFatherName"></span></div>
                    <div class="col-md-2"><strong>Contact:</strong> <span id="displayContact"></span></div>
                </div>
                <div class="row mt-2">
                    <div class="col-md-12">
                        <div class="alert alert-info mb-0">
                            <strong><i class="fas fa-info-circle"></i> Note:</strong>
                            Fees that are already paid can still be selected for new month payments.
                            <span class="badge bg-success">✅ Paid</span> - Click to pay for next month.
                            <span class="badge bg-info">📈 Advance</span> - Advance payments will auto-deduct from next month's bill.
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <input type="hidden" id="hdnStudentId" value="0" />

        <div class="row">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
                        <h5 class="mb-0"><i class="fas fa-list"></i> Select Fees to Pay</h5>
                        <span class="badge bg-light text-dark" id="feeCount">0 fees selected</span>
                    </div>
                    <div class="card-body" id="feeList" style="max-height: 500px; overflow-y: auto;">
                        <div class="text-center text-muted">Loading fees...</div>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card">
                    <div class="card-header bg-warning">
                        <h5 class="mb-0"><i class="fas fa-calculator"></i> Payment Summary</h5>
                    </div>
                    <div class="card-body">
                        <div class="overall-summary">
                            <h6 class="text-muted mb-2">Overall Fee Summary (All Fees)</h6>
                            <div class="row text-center">
                                <div class="col-3"><small>Total Fee</small><h5 id="totalAmount">₹ 0</h5></div>
                                <div class="col-3"><small>Already Paid</small><h5 id="totalPaid">₹ 0</h5></div>
                                <div class="col-3"><small>Total Due</small><h5 id="totalDue">₹ 0</h5></div>
                                <div class="col-3"><small>Advance Balance</small><h5 id="advanceBalance">₹ 0</h5></div>
                            </div>
                        </div>

                        <div id="selectedSummary" class="selected-summary" style="display: none;">
                            <h6 class="text-primary mb-2"><i class="fas fa-check-circle"></i> Selected Fees Summary</h6>
                            <div id="selectedFeesBreakdown"></div>
                            <hr class="my-2">
                            <div class="row">
                                <div class="col-6"><strong>Total Selected Due:</strong></div>
                                <div class="col-6 text-end"><strong id="totalSelectedDueAmount">₹ 0</strong></div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Payment Duration</label>
                            <select class="form-select" id="ddlMonthsToPay">
                                <option value="1">1 Month</option>
                                <option value="2">2 Months</option>
                                <option value="3">3 Months</option>
                                <option value="4">4 Months</option>
                                <option value="5">5 Months</option>
                                <option value="6">6 Months</option>
                                <option value="12">12 Months (Yearly)</option>
                            </select>
                            <small class="text-muted">Select how many months you want to pay</small>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Payment Type</label>
                            <div>
                                <button type="button" class="btn btn-sm payment-type-btn active" data-type="normal">💰 Normal</button>
                                <button type="button" class="btn btn-sm payment-type-btn inactive" data-type="advance">📈 Advance</button>
                                <button type="button" class="btn btn-sm payment-type-btn inactive" data-type="monthly">📅 Monthly</button>
                            </div>
                            <small class="text-muted" id="paymentTypeHint">Pay for current month</small>
                        </div>

                        <div class="row">
                            <div class="col-6 mb-3">
                                <label class="form-label fw-bold">Discount (₹)</label>
                                <input type="number" class="form-control" id="txtDiscount" value="0" step="0.01" min="0" />
                            </div>
                            <div class="col-6 mb-3">
                                <label class="form-label fw-bold">Advance Payment</label>
                                <input type="number" class="form-control" id="txtAdvance" value="0" step="0.01" min="0" />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-6 mb-3">
                                <label class="form-label fw-bold">Payment Amount <span class="text-danger">*</span></label>
                                <input type="number" class="form-control" id="txtPaymentAmount" step="0.01" min="0" placeholder="Enter amount" />
                            </div>
                            <div class="col-6 mb-3">
                                <label class="form-label fw-bold">Payment Method</label>
                                <select class="form-select" id="ddlPaymentMethod">
                                    <option value="Cash">💵 Cash</option>
                                    <option value="Bank Transfer">🏦 Bank Transfer</option>
                                    <option value="Online">💻 Online</option>
                                    <option value="Card">💳 Card</option>
                                </select>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-6 mb-3">
                                <label class="form-label fw-bold">Payment Date</label>
                                <input type="date" class="form-control" id="txtPaymentDate" />
                            </div>
                            <div class="col-6 mb-3">
                                <label class="form-label fw-bold">Invoice No</label>
                                <input type="text" class="form-control" id="txtInvoiceNo" readonly style="background:#f8f9fa" />
                            </div>
                        </div>

                        <div class="alert alert-info">
                            <strong>Payment Details:</strong><br />
                            <div class="row"><div class="col-6">Total Due Amount:</div><div class="col-6 text-end" id="displayDueAmount">₹ 0</div></div>
                            <div class="row"><div class="col-6">Discount Applied:</div><div class="col-6 text-end text-success" id="displayDiscount">- ₹ 0</div></div>
                            <div class="row"><div class="col-6">Amount After Discount:</div><div class="col-6 text-end" id="displayAfterDiscount">₹ 0</div></div>
                            <div class="row"><div class="col-6">Monthly Payment:</div><div class="col-6 text-end" id="displayMonthlyPayment">₹ 0</div></div>
                            <hr />
                            <div class="row"><div class="col-6"><strong>Total to Pay:</strong></div><div class="col-6 text-end"><strong id="lblNetPayable" style="font-size: 18px;">₹ 0</strong></div></div>
                            <div class="row"><div class="col-6"><strong>Remaining Due:</strong></div><div class="col-6 text-end text-warning"><strong id="remainingDue">₹ 0</strong></div></div>
                        </div>

                        <div class="d-grid gap-2">
                            <button class="btn btn-success btn-lg btn-process-payment"><i class="fas fa-money-bill-wave"></i> Process Payment</button>
                            <button class="btn btn-danger btn-cancel-payment"><i class="fas fa-times"></i> Cancel</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card mt-4">
            <div class="card-header bg-secondary text-white">
                <h5 class="mb-0"><i class="fas fa-history"></i> Payment History</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-bordered">
                        <thead class="table-dark">
                            <tr><th>Date</th><th>Invoice No</th><th>Fee Name</th><th>Amount</th><th>Discount</th><th>Method</th><th>Status</th><th>Actions</th></tr>
                        </thead>
                        <tbody id="paymentHistoryBody"><tr><td colspan="8" class="text-center">No payment history</td></tr></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Today's Payments -->
    <div class="card mb-4 mt-4">
        <div class="card-header bg-success text-white">
            <h5 class="mb-0"><i class="fas fa-calendar-day"></i> Today's Payments (<span id="todayDate"></span>)</h5>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered" id="todayPaymentsTable">
                    <thead class="table-dark"><tr><th>Time</th><th>Invoice No</th><th>Student Name</th><th>Roll No</th><th>Amount</th><th>Discount</th><th>Method</th><th>Action</th></tr></thead>
                    <tbody id="tblTodayPayments"><tr><td colspan="8" class="text-center">No payments today</td></tr></tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- All Payments History -->
    <div class="card">
        <div class="card-header bg-info text-white">
            <h5 class="mb-0"><i class="fas fa-history"></i> All Payments History</h5>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered table-striped" id="allPaymentsTable">
                    <thead class="table-dark">
                        <tr><th>Date</th><th>Invoice No</th><th>Student Name</th><th>Roll No</th><th>Class</th><th>Amount</th><th>Discount</th><th>Status</th><th>Actions</th></tr>
                    </thead>
                    <tbody id="tblAllPayments"><tr><td colspan="9" class="text-center">No payments found</td></tr></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Edit Payment Modal -->
<div class="modal fade" id="editPaymentModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-warning">
                <h5 class="modal-title"><i class="fas fa-edit"></i> Edit Payment</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="editInvoiceNo" />
                <div class="mb-3">
                    <label>Amount (₹)</label>
                    <input type="number" class="form-control" id="editAmount" step="0.01" />
                </div>
                <div class="mb-3">
                    <label>Discount (₹)</label>
                    <input type="number" class="form-control" id="editDiscount" step="0.01" />
                </div>
                <div class="mb-3">
                    <label>Payment Method</label>
                    <select class="form-select" id="editMethod">
                        <option value="Cash">Cash</option>
                        <option value="Bank Transfer">Bank Transfer</option>
                        <option value="Online">Online</option>
                        <option value="Card">Card</option>
                    </select>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-primary btn-update-payment">Update Payment</button>
                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            </div>
        </div>
    </div>
</div>

<!-- Receipt Modal -->
<div class="modal fade" id="receiptModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title"><i class="fas fa-receipt"></i> Payment Receipt</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="receiptContent"></div>
            <div class="modal-footer no-print">
                <button class="btn btn-primary btn-print-receipt"><i class="fas fa-print"></i> Print Receipt</button>
                <button class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/buttons/2.4.2/js/dataTables.buttons.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>
<script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.html5.min.js"></script>
<script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.print.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

<script>
    let selectedStudentId = 0;
    let selectedFees = [];
    let dataTable;
    let currentPaymentType = 'normal';
    let editModal;
    let receiptModal;
    let currentStudentData = null;

    $(document).ready(function() {
        let today = new Date();
        $('#todayDate').text(today.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }));
        $('#txtPaymentDate').val(today.toISOString().split('T')[0]);

        editModal = new bootstrap.Modal(document.getElementById('editPaymentModal'));
        receiptModal = new bootstrap.Modal(document.getElementById('receiptModal'));

        loadTodayPayments();
        loadAllPayments();
        loadNepaliDate();

        toastr.options = { "closeButton": true, "progressBar": true, "positionClass": "toast-top-right", "timeOut": "3000" };

        $('.payment-type-btn').click(function() {
            $('.payment-type-btn').removeClass('active').addClass('inactive');
            $(this).removeClass('inactive').addClass('active');
            currentPaymentType = $(this).data('type');

            if (currentPaymentType === 'advance') {
                $('#paymentTypeHint').text('Advance payment will be credited to future months');
                $('#txtAdvance').prop('readonly', false);
            } else if (currentPaymentType === 'monthly') {
                $('#paymentTypeHint').text('Pay in monthly installments');
                $('#txtAdvance').prop('readonly', true);
                $('#txtAdvance').val(0);
            } else {
                $('#paymentTypeHint').text('Pay for current month');
                $('#txtAdvance').prop('readonly', true);
                $('#txtAdvance').val(0);
            }
            calculateNetPayable();
        });

        $('#ddlMonthsToPay').change(function() { calculateNetPayable(); });
    });

    function loadNepaliDate() {
        $.ajax({
            url: '/FeePayment/GetNepaliDate',
            type: 'GET',
            success: function(res) {
                if (res.success) {
                    $('#nepaliDateDisplay').html('<strong>' + res.date + '</strong>');
                }
            }
        });
    }

    $('#btnSearch').click(function() {
        let searchTerm = $('#searchStudent').val().trim();
        if (searchTerm.length < 2) { toastr.warning('Please enter at least 2 characters'); return; }
        $.ajax({ url: '/FeePayment/SearchStudents', type: 'GET', data: { searchTerm: searchTerm }, success: displaySearchResults, error: () => toastr.error('Error searching students') });
    });

    $('#searchStudent').keypress(function(e) { if (e.which == 13) $('#btnSearch').click(); });
    $('#btnClearSearch').click(function() { $('#searchStudent').val(''); $('#searchResults').hide(); });

    function displaySearchResults(students) {
        if (!students || students.length === 0) { $('#searchResults').html('<div class="alert alert-warning">No students found</div>').show(); return; }
        let html = '<div class="list-group">';
        students.forEach(s => {
            html += `<div class="list-group-item search-result-item" data-id="${s.studentID}">
                <div class="d-flex justify-content-between align-items-center">
                    <div><strong>${escapeHtml(s.studentName)}</strong><br/><small>Roll: ${s.rollNo || 'N/A'} | Class: ${escapeHtml(s.className)} | Father: ${escapeHtml(s.fatherName) || 'N/A'}</small></div>
                    <button class="btn btn-sm btn-success btn-select-student" data-id="${s.studentID}"><i class="fas fa-money-bill"></i> Select</button>
                </div>
            </div>`;
        });
        html += '</div>';
        $('#searchResults').html(html).show();
    }

    $(document).on('click', '.btn-select-student', function(e) { e.stopPropagation(); loadStudentDetails($(this).data('id')); });

    function loadStudentDetails(studentId) {
        $('#searchResults').hide(); $('#searchStudent').val('');
        $.ajax({
            url: '/FeePayment/GetStudentFeeDetails',
            type: 'GET',
            data: { studentId: studentId },
            success: function(res) {
                if (res.success) {
                    selectedStudentId = studentId;
                    currentStudentData = res;
                    $('#hdnStudentId').val(studentId);
                    $('#displayStudentName').text(res.student.studentName);
                    $('#displayRollNo').text(res.student.rollNo || 'N/A');
                    $('#displayClass').text(res.student.className);
                    $('#displayFatherName').text(res.student.fatherName || 'N/A');
                    $('#displayContact').text(res.student.contactNo || 'N/A');
                    $('#totalAmount').text('₹ ' + res.totalFeeAmount.toFixed(2));
                    $('#totalPaid').text('₹ ' + res.totalPaidOverall.toFixed(2));
                    $('#totalDue').text('₹ ' + res.totalDueOverall.toFixed(2));
                    $('#advanceBalance').text('₹ ' + (res.advanceBalance || 0).toFixed(2));
                    displayFeeList(res.feeStructures);
                    displayPaymentHistory(res.paymentHistory);
                    $('#paymentSection').show();
                    $('#txtInvoiceNo').val('INV-' + new Date().getTime());
                    $('html, body').animate({ scrollTop: $('#paymentSection').offset().top - 50 }, 500);
                } else { toastr.error(res.message); }
            },
            error: () => toastr.error('Error loading student details')
        });
    }

    function displayFeeList(fees) {
        if (!fees || fees.length === 0) {
            $('#feeList').html('<div class="alert alert-warning">No fees configured for this class</div>');
            return;
        }

        let html = '';
        fees.forEach(fee => {
            let statusClass = fee.isFullyPaid ? 'status-paid' : 'status-due';
            let statusText = fee.isFullyPaid ? '✅ Paid - Select for new month' : `Due: ₹${fee.dueAmount.toFixed(2)}`;
            let bgColor = fee.isFullyPaid ? '#d4edda' : 'white';

            html += `<div class="fee-item" style="background:${bgColor}"
                     data-id="${fee.feeStructureID}"
                     data-name="${escapeHtml(fee.feeName)}"
                     data-amount="${fee.amount}"
                     data-due="${fee.dueAmount}"
                     data-paid="${fee.totalPaid}"
                     data-academic="${fee.academicYear}">
                <div class="form-check">
                    <input class="form-check-input fee-checkbox" type="checkbox"
                           value="${fee.feeStructureID}"
                           id="fee_${fee.feeStructureID}"
                           data-due="${fee.dueAmount}">
                    <label class="form-check-label" for="fee_${fee.feeStructureID}">
                        <strong>${escapeHtml(fee.feeName)}</strong>
                        ${fee.isFullyPaid ? '<span class="fee-paid-badge"><i class="fas fa-check"></i> Paid</span>' : ''}
                        <br/>
                        <small>Total: ₹${fee.amount.toFixed(2)} | Paid: ₹${fee.totalPaid.toFixed(2)} | <span class="${statusClass}">${statusText}</span></small>
                        ${fee.isFullyPaid ? `<br/><small class="text-success">🔄 Select to pay for next month (₹${fee.amount.toFixed(2)})</small>` : ''}
                    </label>
                </div>
            </div>`;
        });
        $('#feeList').html(html);

        $('.fee-checkbox').off('change').on('change', function() {
            updateSelectedFees();
            updateFeeCount();
        });

        updateFeeCount();
    }

    function updateFeeCount() {
        let count = $('.fee-checkbox:checked').length;
        $('#feeCount').text(count + ' fee' + (count > 1 ? 's' : '') + ' selected');
    }

    function updateSelectedFees() {
        selectedFees = [];
        $('.fee-checkbox:checked').each(function() {
            let parent = $(this).closest('.fee-item');
            let dueAmount = parent.data('due');
            let fullAmount = parent.data('amount');

            let amountToUse = dueAmount > 0 ? dueAmount : fullAmount;

            selectedFees.push({
                feeStructureID: parseInt($(this).val()),
                feeName: parent.data('name'),
                amount: fullAmount,
                dueAmount: amountToUse,
                academicYear: parent.data('academic'),
                isFullyPaid: dueAmount <= 0
            });
        });
        updateSelectedSummary();
    }

    function updateSelectedSummary() {
        if (selectedFees.length === 0) {
            $('#selectedSummary').hide();
            $('#txtPaymentAmount').attr('max', 0);
            $('#displayDueAmount').text('₹ 0');
            $('#totalSelectedDueAmount').text('₹ 0');
            $('#lblNetPayable').text('₹ 0');
            $('#remainingDue').text('₹ 0');
            $('#displayDiscount').text('- ₹ 0');
            $('#displayAfterDiscount').text('₹ 0');
            $('#displayMonthlyPayment').text('₹ 0');
            return;
        }

        let breakdownHtml = '';
        let totalSelectedDue = 0;

        selectedFees.forEach(fee => {
            let status = fee.isFullyPaid ? '🔄 New Month' : 'Due';
            breakdownHtml += `<div class="row mb-1">
                <div class="col-7">${escapeHtml(fee.feeName)} ${fee.isFullyPaid ? '<span class="badge bg-success">New Month</span>' : ''}</div>
                <div class="col-5 text-end">₹ ${fee.dueAmount.toFixed(2)}</div>
            </div>`;
            totalSelectedDue += fee.dueAmount;
        });

        $('#selectedFeesBreakdown').html(breakdownHtml);
        $('#totalSelectedDueAmount').text('₹ ' + totalSelectedDue.toFixed(2));
        $('#selectedSummary').show();
        $('#displayDueAmount').text('₹ ' + totalSelectedDue.toFixed(2));

        calculateNetPayable();
    }

    $('#txtDiscount, #txtAdvance, #ddlMonthsToPay').on('keyup change', function() {
        calculateNetPayable();
    });

    function calculateNetPayable() {
        let totalDue = 0;
        selectedFees.forEach(fee => { totalDue += fee.dueAmount; });

        let discount = parseFloat($('#txtDiscount').val()) || 0;
        let advance = parseFloat($('#txtAdvance').val()) || 0;
        let months = parseInt($('#ddlMonthsToPay').val()) || 1;

        if (selectedFees.length === 0) {
            $('#lblNetPayable').text('₹ 0');
            $('#remainingDue').text('₹ 0');
            $('#displayDiscount').text('- ₹ 0');
            $('#displayAfterDiscount').text('₹ 0');
            $('#displayMonthlyPayment').text('₹ 0');
            return;
        }

        if (discount > totalDue) {
            discount = totalDue;
            $('#txtDiscount').val(discount);
        }

        let afterDiscount = totalDue - discount;
        $('#displayDiscount').text('- ₹ ' + discount.toFixed(2));
        $('#displayAfterDiscount').text('₹ ' + afterDiscount.toFixed(2));

        let monthlyPayment = afterDiscount / months;
        $('#displayMonthlyPayment').text('₹ ' + monthlyPayment.toFixed(2));

        let paymentAmount = 0;
        let remainingDue = 0;

        if (currentPaymentType === 'advance') {
            paymentAmount = advance;
            remainingDue = totalDue;
        } else if (currentPaymentType === 'monthly') {
            paymentAmount = monthlyPayment;
            remainingDue = afterDiscount - paymentAmount;
            $('#txtPaymentAmount').val(paymentAmount.toFixed(2));
            $('#txtPaymentAmount').prop('readonly', true);
        } else {
            paymentAmount = parseFloat($('#txtPaymentAmount').val()) || 0;
            if (paymentAmount > afterDiscount) {
                paymentAmount = afterDiscount;
                $('#txtPaymentAmount').val(paymentAmount);
            }
            remainingDue = afterDiscount - paymentAmount;
        }

        $('#lblNetPayable').text('₹ ' + paymentAmount.toFixed(2));
        $('#remainingDue').text('₹ ' + (remainingDue >= 0 ? remainingDue : 0).toFixed(2));

        if (currentPaymentType === 'advance') {
            $('#txtPaymentAmount').val(paymentAmount);
            $('#txtPaymentAmount').prop('readonly', true);
        } else if (currentPaymentType !== 'monthly') {
            $('#txtPaymentAmount').prop('readonly', false);
        }
    }

    $('#txtPaymentAmount').on('keyup change', function() {
        if (currentPaymentType !== 'monthly') {
            calculateNetPayable();
        }
    });

    function displayPaymentHistory(payments) {
        if (!payments || payments.length === 0) {
            $('#paymentHistoryBody').html('<tr><td colspan="8" class="text-center">No payment history</td></tr>');
            return;
        }
        let html = '';
        payments.forEach(p => {
            let statusBadge = p.paymentStatus === 'Paid' ? '<span class="badge bg-success">Paid</span>' :
                p.paymentStatus === 'Advance' ? '<span class="badge bg-info">Advance</span>' :
                '<span class="badge bg-warning">Partial</span>';

            let feeName = p.FeeName || 'N/A';
            if (p.FeeName === 'Advance Payment') {
                feeName = '<span class="badge bg-info">📈 Advance</span>';
            }

            html += `<tr>
                <td>${new Date(p.paymentDate).toLocaleDateString()}</td>
                <td><strong>${p.invoiceNo}</strong></td>
                <td>${feeName}</td>
                <td>₹ ${p.paidAmount.toFixed(2)}</td>
                <td>₹ ${(p.discount || 0).toFixed(2)}</td>
                <td>${p.paymentMethod}</td>
                <td>${statusBadge}</td>
                <td>
                    <button class="btn btn-sm btn-info btn-view-receipt" data-invoice="${p.invoiceNo}"><i class="fas fa-print"></i></button>
                </td>
            </tr>`;
        });
        $('#paymentHistoryBody').html(html);
    }

    // ============================================================
    // FIXED: Process Payment - Sends correct data to server
    // ============================================================
    $('.btn-process-payment').click(function() {
        let paymentAmount = parseFloat($('#txtPaymentAmount').val());
        let discount = parseFloat($('#txtDiscount').val()) || 0;
        let advance = parseFloat($('#txtAdvance').val()) || 0;
        let months = parseInt($('#ddlMonthsToPay').val()) || 1;
        let selectedFeeIds = [];
        let selectedFeesData = [];

        // Get selected fees data
        $('.fee-checkbox:checked').each(function() {
            let parent = $(this).closest('.fee-item');
            let dueAmount = parent.data('due');
            let fullAmount = parent.data('amount');
            let amountToUse = dueAmount > 0 ? dueAmount : fullAmount;

            selectedFeeIds.push(parseInt($(this).val()));
            selectedFeesData.push({
                feeStructureID: parseInt($(this).val()),
                feeName: parent.data('name'),
                amount: fullAmount,
                dueAmount: amountToUse,
                academicYear: parent.data('academic')
            });
        });

        if (selectedFeeIds.length === 0) { toastr.warning('Please select at least one fee to pay'); return; }
        if (paymentAmount <= 0 && advance <= 0) { toastr.warning('Please enter payment amount'); return; }

        let totalDue = selectedFeesData.reduce((sum, fee) => sum + fee.dueAmount, 0);
        let afterDiscount = totalDue - discount;

        if (paymentAmount > afterDiscount && currentPaymentType !== 'advance' && currentPaymentType !== 'monthly') {
            toastr.warning(`Payment amount cannot exceed ₹${afterDiscount.toFixed(2)}`);
            return;
        }

        let data = {
            StudentID: selectedStudentId,
            FeeStructureIds: selectedFeeIds, // Send all selected fee IDs
            SelectedFees: selectedFeesData, // Send full fee data with amounts
            PaidAmount: currentPaymentType === 'monthly' ? afterDiscount : paymentAmount,
            Discount: discount,
            AdvanceAmount: advance,
            MonthsToPay: months,
            PaymentType: currentPaymentType,
            PaymentMethod: $('#ddlPaymentMethod').val(),
            PaymentDate: $('#txtPaymentDate').val(),
            InvoiceNo: $('#txtInvoiceNo').val(),
            TotalDue: totalDue,
            AfterDiscount: afterDiscount
        };

        console.log('Sending data:', data); // Debug

        $.ajax({
            url: '/FeePayment/SaveBulkPayment',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(data),
            success: function(res) {
                if (res.success) {
                    toastr.success('Payment processed successfully!');
                    if (res.isAdvance) {
                        toastr.info(`Advance payment of ₹${res.advanceAmount.toFixed(2)} will be credited to next month`);
                    }
                    // Show receipt and refresh data
                    showReceipt(res.invoiceNo);
                    loadStudentDetails(selectedStudentId);
                    loadTodayPayments();
                    loadAllPayments();
                    $('.fee-checkbox:checked').prop('checked', false);
                    $('#txtPaymentAmount').val('');
                    $('#txtDiscount').val('0');
                    $('#txtAdvance').val('0');
                    selectedFees = [];
                    updateSelectedSummary();
                    updateFeeCount();
                } else { toastr.error(res.message); }
            },
            error: function(xhr) {
                console.log('Error:', xhr);
                toastr.error(xhr.responseJSON?.message || 'Error processing payment');
            }
        });
    });

    $('.btn-cancel-payment').click(function() {
        $('#paymentSection').hide();
        $('#searchStudent').val('');
        $('#searchResults').hide();
        selectedStudentId = 0;
        selectedFees = [];
    });

    // Show Receipt
    function showReceipt(invoiceNo) {
        $.ajax({
            url: '/FeePayment/GetReceiptByInvoice',
            type: 'GET',
            data: { invoiceNo: invoiceNo },
            success: function(receipt) {
                displayReceipt(receipt);
                receiptModal.show();
            },
            error: function(xhr) {
                console.log('Error:', xhr);
                toastr.error('Error loading receipt');
            }
        });
    }

    // Display Receipt
    function displayReceipt(receipt) {
        console.log('Receipt Data:', receipt); // Debug

        let feeDetailsHtml = '';
        let subtotal = 0;
        let totalDiscount = 0;

        // Build fee details rows
        if (receipt.feeDetails && receipt.feeDetails.length > 0) {
            receipt.feeDetails.forEach(function(f) {
                let statusClass = f.dueAfter <= 0 ? 'bg-success' : 'bg-warning';
                let statusText = f.dueAfter <= 0 ? 'Paid' : 'Partial';

                subtotal += parseFloat(f.totalAmount) || 0;
                totalDiscount += parseFloat(f.discount) || 0;

                feeDetailsHtml += `<tr>
                    <td>${escapeHtml(f.feeName) || 'N/A'}</td>
                    <td style="text-align:right;">₹ ${(parseFloat(f.totalAmount) || 0).toFixed(2)}</td>
                    <td style="text-align:right;">₹ ${(parseFloat(f.paidAmount) || 0).toFixed(2)}</td>
                    <td style="text-align:right;">${(parseFloat(f.discount) || 0) > 0 ? '₹ ' + parseFloat(f.discount).toFixed(2) : '-'}</td>
                    <td style="text-align:center;"><span class="badge ${statusClass}">${statusText}</span></td>
                    <td style="text-align:right;">₹ ${(parseFloat(f.dueAfter) || 0).toFixed(2)}</td>
                </tr>`;
            });
        } else {
            feeDetailsHtml = `<tr><td colspan="6" style="text-align:center;color:#999;">No fee details available</td></tr>`;
        }

        // Get values from receipt
        let totalFee = parseFloat(receipt.totalFee) || subtotal;
        let totalPaid = parseFloat(receipt.totalPaid) || 0;
        let totalDisc = parseFloat(receipt.totalDiscount) || totalDiscount;
        let advanceAmt = parseFloat(receipt.advanceAmount) || 0;
        let dueAmt = parseFloat(receipt.dueAmount) || 0;

        let receiptHtml = `<div class="receipt-card">
            <div class="receipt-header">
                <div class="receipt-school-name">🏫 School Management System</div>
                <div class="receipt-title">Fee Payment Receipt</div>
                <div class="receipt-divider"></div>
            </div>

            <div class="row">
                <div class="col-6">
                    <p><strong>Invoice No:</strong> ${receipt.invoiceNo || 'N/A'}</p>
                    <p><strong>Date:</strong> ${receipt.paymentDate ? new Date(receipt.paymentDate).toLocaleDateString() : 'N/A'}</p>
                    <p><strong>Payment Method:</strong> ${receipt.paymentMethod || 'N/A'}</p>
                </div>
                <div class="col-6 text-end">
                    <div class="receipt-nepali-date">
                        <strong><i class="fas fa-calendar-alt"></i> Nepali Date:</strong><br/>
                        ${receipt.nepaliDate || 'N/A'}
                    </div>
                    <p class="mt-2"><strong>Payment Type:</strong>
                        <span class="badge ${receipt.paymentType === 'Advance' ? 'bg-info' : 'bg-primary'}">
                            ${receipt.paymentType || 'Normal'}
                        </span>
                    </p>
                    ${advanceAmt > 0 ? `<p><strong>Advance Amount:</strong> <span class="text-info">₹ ${advanceAmt.toFixed(2)}</span></p>` : ''}
                </div>
            </div>

            <div class="receipt-divider"></div>

            <div class="row">
                <div class="col-12">
                    <h6>Student Information:</h6>
                    <p><strong>Name:</strong> ${escapeHtml(receipt.studentName) || 'N/A'}<br/>
                    <strong>Roll No:</strong> ${receipt.rollNo || 'N/A'}<br/>
                    <strong>Class:</strong> ${escapeHtml(receipt.className) || 'N/A'}<br/>
                    <strong>Father's Name:</strong> ${escapeHtml(receipt.fatherName) || 'N/A'}</p>
                </div>
            </div>

            <div class="receipt-divider"></div>

            <div class="row">
                <div class="col-12">
                    <h6>Fee Details:</h6>
                    <table class="receipt-table">
                        <thead>
                            <tr>
                                <th>Fee Name</th>
                                <th style="text-align:right;">Total Amount</th>
                                <th style="text-align:right;">Paid Amount</th>
                                <th style="text-align:right;">Discount</th>
                                <th style="text-align:center;">Status</th>
                                <th style="text-align:right;">Due After</th>
                            </tr>
                        </thead>
                        <tbody>
                            ${feeDetailsHtml}
                        </tbody>
                        <tfoot>
                            <tr style="background-color: #f8f9fa;">
                                <th colspan="5" style="text-align:right;">Subtotal</th>
                                <th style="text-align:right;">₹ ${totalFee.toFixed(2)}</th>
                            </tr>
                            ${totalDisc > 0 ? `<tr style="background-color: #f8f9fa;">
                                <th colspan="5" style="text-align:right;color:green;">Total Discount</th>
                                <th style="text-align:right;color:green;">- ₹ ${totalDisc.toFixed(2)}</th>
                            </tr>` : ''}
                            ${advanceAmt > 0 ? `<tr style="background-color: #e3f2fd;">
                                <th colspan="5" style="text-align:right;color:#17a2b8;">Advance Payment</th>
                                <th style="text-align:right;color:#17a2b8;">₹ ${advanceAmt.toFixed(2)}</th>
                            </tr>` : ''}
                            <tr style="background-color: #e8f5e9;">
                                <th colspan="5" style="text-align:right;"><strong>Total Paid</strong></th>
                                <th style="text-align:right;"><strong>₹ ${totalPaid.toFixed(2)}</strong></th>
                            </tr>
                            <tr style="background-color: ${dueAmt <= 0 ? '#d4edda' : '#f8d7da'};">
                                <th colspan="5" style="text-align:right;${dueAmt <= 0 ? 'color:green;' : 'color:red;'}">
                                    ${dueAmt <= 0 ? '✅ Fully Paid' : '⚠️ Remaining Due'}
                                </th>
                                <th style="text-align:right;${dueAmt <= 0 ? 'color:green;' : 'color:red;'}">
                                    ₹ ${dueAmt.toFixed(2)}
                                </th>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>

            <div class="receipt-divider"></div>

            <div class="receipt-footer">
                <p><strong>✅ Thank you for your payment!</strong></p>
                <small>This is a computer generated receipt | Nepali Date: ${receipt.nepaliDate || 'N/A'}</small>
            </div>
        </div>`;

        $('#receiptContent').html(receiptHtml);
    }

    $('.btn-print-receipt').click(function() {
        let printContents = $('#receiptContent').html();
        let originalContents = document.body.innerHTML;
        document.body.innerHTML = printContents;
        window.print();
        document.body.innerHTML = originalContents;
        location.reload();
    });

    $(document).on('click', '.btn-edit-payment', function() {
        let invoiceNo = $(this).data('invoice');
        let amount = $(this).data('amount');
        let discount = $(this).data('discount');
        let method = $(this).data('method');

        $('#editInvoiceNo').val(invoiceNo);
        $('#editAmount').val(amount);
        $('#editDiscount').val(discount);
        $('#editMethod').val(method);
        editModal.show();
    });

    $('.btn-update-payment').click(function() {
        let data = {
            InvoiceNo: $('#editInvoiceNo').val(),
            PaidAmount: $('#editAmount').val(),
            Discount: $('#editDiscount').val(),
            PaymentMethod: $('#editMethod').val()
        };

        $.ajax({
            url: '/FeePayment/EditPayment',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(data),
            success: function(res) {
                if (res.success) {
                    toastr.success('Payment updated successfully');
                    editModal.hide();
                    loadStudentDetails(selectedStudentId);
                    loadTodayPayments();
                    loadAllPayments();
                } else { toastr.error(res.message); }
            }
        });
    });

    $(document).on('click', '.btn-delete-payment', function() {
        let invoiceNo = $(this).data('invoice');
        if (confirm('Are you sure you want to delete this payment? This action cannot be undone!')) {
            $.ajax({
                url: '/FeePayment/DeletePayment',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(invoiceNo),
                success: function(res) {
                    if (res.success) {
                        toastr.success('Payment deleted successfully');
                        loadStudentDetails(selectedStudentId);
                        loadTodayPayments();
                        loadAllPayments();
                    } else { toastr.error(res.message); }
                }
            });
        }
    });

    function loadTodayPayments() {
        $.ajax({
            url: '/FeePayment/GetTodayPayments',
            type: 'GET',
            success: function(payments) {
                let html = '';
                if (payments && payments.length > 0) {
                    payments.forEach(p => {
                        html += `<tr class="today-row">
                            <td>${new Date(p.paymentDate).toLocaleTimeString()}</td>
                            <td><strong>${p.invoiceNo}</strong></td>
                            <td>${escapeHtml(p.studentName)}</td>
                            <td>${p.rollNo || '-'}</td>
                            <td>₹ ${p.totalAmount.toFixed(2)}</td>
                            <td>₹ ${(p.discount || 0).toFixed(2)}</td>
                            <td>${p.paymentMethod}</td>
                            <td><button class="btn btn-sm btn-info btn-view-receipt" data-invoice="${p.invoiceNo}"><i class="fas fa-print"></i></button></td>
                        </tr>`;
                    });
                } else {
                    html = '<tr><td colspan="8" class="text-center">No payments today</td></tr>';
                }
                $('#tblTodayPayments').html(html);
            }
        });
    }

    function loadAllPayments() {
        $.ajax({
            url: '/FeePayment/GetAllPayments',
            type: 'GET',
            success: function(payments) {
                let html = '';
                if (payments && payments.length > 0) {
                    payments.forEach(p => {
                        let status = p.dueAfter <= 0 ? 'Paid' : 'Partial';
                        let statusBadge = status === 'Paid' ?
                            '<span class="badge bg-success">Paid</span>' :
                            '<span class="badge bg-warning">Partial</span>';

                        html += `<tr>
                            <td>${new Date(p.paymentDate).toLocaleDateString()}</td>
                            <td><strong>${p.invoiceNo}</strong></td>
                            <td>${escapeHtml(p.studentName)}</td>
                            <td>${p.rollNo || '-'}</td>
                            <td>${escapeHtml(p.className)}</td>
                            <td>₹ ${p.totalAmount.toFixed(2)}</td>
                            <td>₹ ${(p.discount || 0).toFixed(2)}</td>
                            <td>${statusBadge}</td>
                            <td>
                                <button class="btn btn-sm btn-warning btn-edit-payment" data-invoice="${p.invoiceNo}" data-amount="${p.totalAmount}" data-discount="${p.discount}" data-method="${p.paymentMethod}"><i class="fas fa-edit"></i></button>
                                <button class="btn btn-sm btn-danger btn-delete-payment" data-invoice="${p.invoiceNo}"><i class="fas fa-trash"></i></button>
                                <button class="btn btn-sm btn-info btn-view-receipt" data-invoice="${p.invoiceNo}"><i class="fas fa-print"></i></button>
                            </td>
                        </tr>`;
                    });
                } else {
                    html = '<tr><td colspan="9" class="text-center">No payments found</td></tr>';
                }
                $('#tblAllPayments').html(html);

                if ($.fn.DataTable.isDataTable('#allPaymentsTable')) {
                    $('#allPaymentsTable').DataTable().destroy();
                }

                dataTable = $('#allPaymentsTable').DataTable({
                    dom: 'Bfrtip',
                    buttons: [
                        { extend: 'copy', className: 'btn-sm' },
                        { extend: 'csv', className: 'btn-sm' },
                        { extend: 'excel', className: 'btn-sm', title: 'Payments_History' },
                        { extend: 'pdf', className: 'btn-sm', title: 'Payments_History' },
                        { extend: 'print', className: 'btn-sm', title: 'Payments History Report' }
                    ],
                    pageLength: 10,
                    lengthMenu: [
                        [10, 25, 50, 100, -1],
                        [10, 25, 50, 100, "All"]
                    ],
                    language: { search: "Search:", lengthMenu: "Show _MENU_ entries", info: "Showing _START_ to _END_ of _TOTAL_ entries" },
                    order: [
                        [0, 'desc']
                    ]
                });
            }
        });
    }

    $(document).on('click', '.btn-view-receipt', function() {
        showReceipt($(this).data('invoice'));
    });

    function escapeHtml(str) {
        if (!str) return '';
        return str.replace(/[&<>]/g, function(m) {
            if (m === '&') return '&amp;';
            if (m === '<') return '&lt;';
            if (m === '>') return '&gt;';
            return m;
        });
    }
</script>