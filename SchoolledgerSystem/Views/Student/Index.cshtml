<link rel="stylesheet" href="~/css/student.css" />

<h2 class="title">Student Management System</h2>

<div class="container">

    <!-- SEARCH -->
    <div class="card">

        <div class="row">

            <div class="col">
                <label>Roll No</label>
                <input type="text" class="txtSearchRoll form-control" />
            </div>

            <div class="col">
                <label>Name</label>
                <input type="text" class="txtSearchName form-control" />
            </div>

            <div class="col buttons">
                <button class="btnSearch">Search</button>
                <button class="btnCreate">Add Student</button>
            </div>

        </div>

    </div>

    <!-- TABLE -->
    <div class="card mt-3">

        <table class="tblStudent">

            <thead>
                <tr>
                    <th>SN</th>
                    <th>Roll No</th>
                    <th>Name</th>
                    <th>Class</th>
                    <th>Phone</th>
                    <th>Action</th>
                </tr>
            </thead>

            <tbody class="main-data"></tbody>

        </table>

    </div>

</div>

<!-- SIMPLE MODAL -->
<div id="mdlStudent" class="modal">

    <div class="modal-content">

        <h3>Student Form</h3>

        <input type="text" class="txtRollNo" placeholder="Roll No" />
        <input type="text" class="txtFullName" placeholder="Full Name" />
        <input type="text" class="txtClass" placeholder="Class" />
        <input type="text" class="txtPhone" placeholder="Phone" />

        <input type="hidden" class="hdnId" value="0" />

        <div class="modal-actions">
            <button class="btnSave">Save</button>
            <button id="btnCancel">Cancel</button>
        </div>

    </div>

</div>

<script src="~/js/student.js"></script>