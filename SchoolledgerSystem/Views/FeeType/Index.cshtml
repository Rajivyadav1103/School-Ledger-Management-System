@{
    ViewData["Title"] = "Fee Type";
}

<div class="container mt-3">
    <h2>Fee Type Management</h2>
    <hr />

    <button class="btn btn-success mb-3 btnAdd">
        + Add Fee Type
    </button>

    <div class="table-responsive">
        <table class="table table-bordered table-hover">
            <thead class="table-dark">
                <tr>
                    <th>SN</th>
                    <th>Fee Code</th>
                    <th>Fee Name</th>
                    <th>Amount (Rs.)</th>
                    <th>Status</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody id="tblData">
                <tr>
                    <td colspan="6" class="text-center">Loading...</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<!-- MODAL -->
<div class="modal fade" id="feeModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">Fee Type Details</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <input type="hidden" id="hdnId" value="0" />

                <div class="mb-3">
                    <label class="form-label fw-bold">Fee Code <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" id="txtFeeCode" placeholder="Enter fee code (e.g., FEE001)" maxlength="20" />
                    <small class="text-muted">Unique identifier for the fee type</small>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Fee Name <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" id="txtName" placeholder="Enter fee name" />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Amount <span class="text-danger">*</span></label>
                    <input type="number" class="form-control" id="txtAmount" placeholder="Enter amount" step="0.01" min="0" />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Description</label>
                    <textarea class="form-control" id="txtDescription" rows="3" placeholder="Enter description (optional)"></textarea>
                </div>

                <div class="form-check mb-3">
                    <input type="checkbox" class="form-check-input" id="txtActive" checked>
                    <label class="form-check-label fw-bold" for="txtActive">Is Active</label>
                </div>
            </div>

            <div class="modal-footer">
                <button class="btn btn-primary btnSave">Save</button>
                <button class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
<link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet" />
<script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

<script>
    let modal;

    $(document).ready(function () {
        modal = new bootstrap.Modal(document.getElementById('feeModal'));
        loadData();

        toastr.options = {
            "closeButton": true,
            "progressBar": true,
            "positionClass": "toast-top-right",
            "timeOut": "3000"
        };
    });

    function loadData() {
        $.ajax({
            url: '/FeeType/GetAll',
            type: 'GET',
            success: function (res) {
                let html = '';

                if (res && res.length > 0) {
                    $.each(res, function (i, item) {
                        let statusBadge = item.isActive
                            ? '<span class="badge bg-success">Active</span>'
                            : '<span class="badge bg-danger">Inactive</span>';

                        html += `
                            <tr>
                                <td>${i + 1}</td>
                                <td><strong>${item.feeCode || '-'}</strong></td>
                                <td>${item.feeName || '-'}</td>
                                <td>${parseFloat(item.amount).toFixed(2)}</td>
                                <td>${statusBadge}</td>
                                <td>
                                    <button class="btn btn-sm btn-warning btnEdit" data-id="${item.feeTypeID}">Edit</button>
                                    <button class="btn btn-sm btn-danger btnDelete" data-id="${item.feeTypeID}">Delete</button>
                                </td>
                            </tr>`;
                    });
                } else {
                    html = '<tr><td colspan="6" class="text-center">No records found</td></tr>';
                }

                $('#tblData').html(html);
            },
            error: function (xhr, status, error) {
                $('#tblData').html('<tr><td colspan="6" class="text-center text-danger">Error loading data</td></tr>');
                toastr.error('Failed to load data');
                console.error(error);
            }
        });
    }

    // ADD BUTTON
    $('.btnAdd').click(function () {
        clearForm();
        modal.show();
    });

    // SAVE BUTTON
    $('.btnSave').click(function () {
        // Validation
        let feeCode = $('#txtFeeCode').val().trim();
        let feeName = $('#txtName').val().trim();
        let amount = $('#txtAmount').val().trim();

        if (!feeCode) {
            toastr.warning('Please enter fee code');
            $('#txtFeeCode').focus();
            return;
        }

        if (!feeName) {
            toastr.warning('Please enter fee name');
            $('#txtName').focus();
            return;
        }

        if (!amount) {
            toastr.warning('Please enter amount');
            $('#txtAmount').focus();
            return;
        }

        if (parseFloat(amount) < 0) {
            toastr.warning('Amount cannot be negative');
            return;
        }

        let data = {
            FeeTypeID: parseInt($('#hdnId').val()) || 0,
            FeeCode: feeCode,
            FeeName: feeName,
            Amount: parseFloat(amount),
            Description: $('#txtDescription').val().trim() || null,
            IsActive: $('#txtActive').is(':checked')
        };

        $.ajax({
            url: '/FeeType/Save',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(data),
            success: function (res) {
                if (res.success) {
                    toastr.success(res.message);
                    modal.hide();
                    loadData();
                    clearForm();
                } else {
                    toastr.error(res.message);
                }
            },
            error: function (xhr, status, error) {
                console.log('Error details:', xhr.responseText);
                let errorMsg = 'An error occurred while saving';
                if (xhr.responseJSON && xhr.responseJSON.message) {
                    errorMsg = xhr.responseJSON.message;
                }
                toastr.error(errorMsg);
            }
        });
    });

    // EDIT BUTTON
    $(document).on('click', '.btnEdit', function () {
        let id = $(this).data('id');

        $.ajax({
            url: '/FeeType/GetById',
            type: 'GET',
            data: { id: id },
            success: function (res) {
                if (res && res.feeTypeID) {
                    $('#hdnId').val(res.feeTypeID);
                    $('#txtFeeCode').val(res.feeCode);
                    $('#txtName').val(res.feeName);
                    $('#txtAmount').val(res.amount);
                    $('#txtDescription').val(res.description || '');
                    $('#txtActive').prop('checked', res.isActive);
                    modal.show();
                } else {
                    toastr.error('Record not found');
                }
            },
            error: function () {
                toastr.error('Failed to load record details');
            }
        });
    });

    // DELETE BUTTON
    $(document).on('click', '.btnDelete', function () {
        let id = $(this).data('id');

        if (confirm('Are you sure you want to delete this record?')) {
            $.ajax({
                url: '/FeeType/Delete',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(id),
                success: function (res) {
                    if (res.success) {
                        toastr.success(res.message);
                        loadData();
                    } else {
                        toastr.error(res.message);
                    }
                },
                error: function (xhr, status, error) {
                    console.error('Delete error:', error);
                    toastr.error('Failed to delete record');
                }
            });
        }
    });

    function clearForm() {
        $('#hdnId').val(0);
        $('#txtFeeCode').val('');
        $('#txtName').val('');
        $('#txtAmount').val('');
        $('#txtDescription').val('');
        $('#txtActive').prop('checked', true);
    }
</script>