@{
    ViewData["Title"] = "Fee Structure Management";
}

<div class="container mt-3">
    <h2>Fee Structure Management</h2>
    <hr />

    <button class="btn btn-success mb-3 btnAdd">
        <i class="fas fa-plus"></i> Add Fee Structure
    </button>

    <div class="table-responsive">
        <table class="table table-bordered table-hover">
            <thead class="table-dark">
                <tr>
                    <th>SN</th>
                    <th>Class Type</th>
                    <th>Fee Type</th>
                    <th>Fee Code</th>
                    <th>Amount (Rs.)</th>
                    <th>Academic Year</th>
                    <th>Status</th>
                    <th>Created Date</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody id="tblData">
                <tr>
                    <td colspan="9" class="text-center">Loading...</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<!-- MODAL -->
<div class="modal fade" id="feeStructureModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">Fee Structure Details</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <input type="hidden" id="hdnId" value="0" />

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Class Type <span class="text-danger">*</span></label>
                        <select class="form-select" id="ddlClassType">
                            <option value="">-- Select Class Type --</option>
                        </select>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Fee Type <span class="text-danger">*</span></label>
                        <select class="form-select" id="ddlFeeType">
                            <option value="">-- Select Fee Type --</option>
                        </select>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Amount (Rs.) <span class="text-danger">*</span></label>
                        <input type="number" class="form-control" id="txtAmount" placeholder="Enter amount" step="0.01" min="0" />
                        <small class="text-muted">Leave as 0 to use Fee Type default amount</small>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Academic Year</label>
                        <select class="form-select" id="ddlAcademicYear">
                            <option value="">-- Select Academic Year --</option>
                        </select>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Description</label>
                    <textarea class="form-control" id="txtDescription" rows="3" placeholder="Enter description (optional)"></textarea>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <div class="form-check">
                            <input type="checkbox" class="form-check-input" id="chkActive" checked>
                            <label class="form-check-label fw-bold" for="chkActive">Is Active</label>
                        </div>
                    </div>

                    <div class="col-md-6 mb-3">
                        <div id="defaultAmountInfo" class="alert alert-info" style="display: none;">
                            <small><i class="fas fa-info-circle"></i> Default amount for this fee type: Rs. <span id="defaultAmount">0</span></small>
                        </div>
                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <button class="btn btn-primary btnSave">
                    <i class="fas fa-save"></i> Save
                </button>
                <button class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="fas fa-times"></i> Close
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Include required libraries -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet" />
<script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

<script>
    let modal;

    $(document).ready(function () {
        modal = new bootstrap.Modal(document.getElementById('feeStructureModal'));
        loadData();
        loadClassTypes();
        loadFeeTypes();
        loadAcademicYears();

        toastr.options = {
            "closeButton": true,
            "progressBar": true,
            "positionClass": "toast-top-right",
            "timeOut": "3000"
        };
    });

    function loadData() {
        $.ajax({
            url: '/FeeStructure/GetAll',
            type: 'GET',
            success: function (res) {
                let html = '';

                if (res && res.length > 0) {
                    $.each(res, function (i, item) {
                        let statusBadge = item.isActive
                            ? '<span class="badge bg-success">Active</span>'
                            : '<span class="badge bg-danger">Inactive</span>';

                        let createdDate = item.createdDate ? new Date(item.createdDate).toLocaleDateString() : '-';

                        html += `
                            <tr>
                                <td>${i + 1}</td>
                                <td><strong>${escapeHtml(item.classTypeName)}</strong></td>
                                <td>${escapeHtml(item.feeTypeName)}</td>
                                <td><span class="badge bg-secondary">${escapeHtml(item.feeCode)}</span></td>
                                <td>${parseFloat(item.amount).toFixed(2)}</td>
                                <td>${escapeHtml(item.academicYear) || '-'}</td>
                                <td>${statusBadge}</td>
                                <td>${createdDate}</td>
                                <td>
                                    <button class="btn btn-sm btn-warning btnEdit me-1" data-id="${item.feeStructureID}">
                                        <i class="fas fa-edit"></i> Edit
                                    </button>
                                    <button class="btn btn-sm btn-danger btnDelete" data-id="${item.feeStructureID}">
                                        <i class="fas fa-trash"></i> Delete
                                    </button>
                                </td>
                            </tr>`;
                    });
                } else {
                    html = '<tr><td colspan="9" class="text-center">No records found</td></tr>';
                }

                $('#tblData').html(html);
            },
            error: function (xhr, status, error) {
                $('#tblData').html('<tr><td colspan="9" class="text-center text-danger">Error loading data</td></tr>');
                toastr.error('Failed to load data');
                console.error(error);
            }
        });
    }

    function loadClassTypes() {
        $.ajax({
            url: '/FeeStructure/GetClassTypes',
            type: 'GET',
            success: function (res) {
                let options = '<option value="">-- Select Class Type --</option>';
                $.each(res, function (i, item) {
                    options += `<option value="${item.classTypeID}">${escapeHtml(item.typeName)}</option>`;
                });
                $('#ddlClassType').html(options);
            },
            error: function () {
                toastr.error('Failed to load class types');
            }
        });
    }

    function loadFeeTypes() {
        $.ajax({
            url: '/FeeStructure/GetFeeTypes',
            type: 'GET',
            success: function (res) {
                let options = '<option value="">-- Select Fee Type --</option>';
                $.each(res, function (i, item) {
                    options += `<option value="${item.feeTypeID}" data-amount="${item.amount}">${escapeHtml(item.feeName)} (${escapeHtml(item.feeCode)})</option>`;
                });
                $('#ddlFeeType').html(options);
            },
            error: function () {
                toastr.error('Failed to load fee types');
            }
        });
    }

    function loadAcademicYears() {
        const currentYear = new Date().getFullYear();
        let options = '<option value="">-- Select Academic Year --</option>';

        for (let i = -2; i <= 2; i++) {
            let year = currentYear + i;
            let nextYear = year + 1;
            let academicYear = `${year}-${nextYear}`;
            options += `<option value="${academicYear}">${academicYear}</option>`;
        }

        $('#ddlAcademicYear').html(options);
    }

    // When Fee Type changes, show default amount
    $('#ddlFeeType').change(function() {
        let selectedOption = $(this).find('option:selected');
        let defaultAmount = selectedOption.data('amount');

        if (defaultAmount && defaultAmount > 0) {
            $('#defaultAmount').text(parseFloat(defaultAmount).toFixed(2));
            $('#defaultAmountInfo').show();

            // Auto-fill amount if empty
            if (!$('#txtAmount').val()) {
                $('#txtAmount').val(defaultAmount);
            }
        } else {
            $('#defaultAmountInfo').hide();
        }
    });

    // ADD BUTTON
    $('.btnAdd').click(function () {
        clearForm();
        modal.show();
    });

    // SAVE BUTTON
    $('.btnSave').click(function () {
        // Validation
        let classTypeId = $('#ddlClassType').val();
        let feeTypeId = $('#ddlFeeType').val();
        let amount = $('#txtAmount').val().trim();

        if (!classTypeId) {
            toastr.warning('Please select a class type');
            $('#ddlClassType').focus();
            return;
        }

        if (!feeTypeId) {
            toastr.warning('Please select a fee type');
            $('#ddlFeeType').focus();
            return;
        }

        if (!amount || parseFloat(amount) <= 0) {
            toastr.warning('Please enter a valid amount greater than 0');
            $('#txtAmount').focus();
            return;
        }

        let data = {
            FeeStructureID: parseInt($('#hdnId').val()) || 0,
            ClassTypeID: parseInt(classTypeId),
            FeeTypeID: parseInt(feeTypeId),
            Amount: parseFloat(amount),
            AcademicYear: $('#ddlAcademicYear').val() || null,
            Description: $('#txtDescription').val().trim() || null,
            IsActive: $('#chkActive').is(':checked')
        };

        $.ajax({
            url: '/FeeStructure/Save',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(data),
            success: function (res) {
                if (res.success) {
                    toastr.success(res.message);
                    modal.hide();
                    loadData();
                    clearForm();
                } else {
                    toastr.error(res.message);
                }
            },
            error: function (xhr, status, error) {
                console.log('Error details:', xhr.responseText);
                let errorMsg = 'An error occurred while saving';
                if (xhr.responseJSON && xhr.responseJSON.message) {
                    errorMsg = xhr.responseJSON.message;
                }
                toastr.error(errorMsg);
            }
        });
    });

    // EDIT BUTTON
    $(document).on('click', '.btnEdit', function () {
        let id = $(this).data('id');

        $.ajax({
            url: '/FeeStructure/GetById',
            type: 'GET',
            data: { id: id },
            success: function (res) {
                if (res && res.feeStructureID) {
                    $('#hdnId').val(res.feeStructureID);
                    $('#ddlClassType').val(res.classTypeID);
                    $('#ddlFeeType').val(res.feeTypeID).trigger('change');
                    $('#txtAmount').val(res.amount);
                    $('#ddlAcademicYear').val(res.academicYear);
                    $('#txtDescription').val(res.description || '');
                    $('#chkActive').prop('checked', res.isActive);
                    modal.show();
                } else {
                    toastr.error('Record not found');
                }
            },
            error: function () {
                toastr.error('Failed to load record details');
            }
        });
    });

    // DELETE BUTTON with SweetAlert
    $(document).on('click', '.btnDelete', function () {
        let id = $(this).data('id');

        Swal.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            confirmButtonText: 'Yes, delete it!'
        }).then((result) => {
            if (result.isConfirmed) {
                $.ajax({
                    url: '/FeeStructure/Delete',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(id),
                    success: function (res) {
                        if (res.success) {
                            toastr.success(res.message);
                            loadData();
                        } else {
                            toastr.error(res.message);
                        }
                    },
                    error: function (xhr, status, error) {
                        console.error('Delete error:', error);
                        toastr.error('Failed to delete record');
                    }
                });
            }
        });
    });

    function clearForm() {
        $('#hdnId').val(0);
        $('#ddlClassType').val('');
        $('#ddlFeeType').val('');
        $('#txtAmount').val('');
        $('#ddlAcademicYear').val('');
        $('#txtDescription').val('');
        $('#chkActive').prop('checked', true);
        $('#defaultAmountInfo').hide();
    }

    function escapeHtml(str) {
        if (!str) return '';
        return str
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
    }
</script>

<!-- SweetAlert2 for better delete confirmation -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>